
@{
    /* الـ Layout بييجي أوتوماتيك من Views/Admin/_ViewStart.cshtml (_AdminLayout) */
    ViewData["PageTitle"] = "لوحة التحكم الرئيسية";
    ViewData["PageSubtitle"] = "نظرة عامة على أداء المنصة اليوم";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" />
}

<!-- KPI ledger -->
<div class="kpi-ledger">
    <div class="kpi">
        <div class="label">إجمالي المدرّسين</div>
        <div class="value"></div>
        <div class="delta up"> هذا الشهر</div>
    </div>
    <div class="kpi">
        <div class="label"></div>
        <div class="value">TotalCourses</div>
        <div class="delta up">CoursesGrowthPercent% هذا الشهر</div>
    </div>
    <div class="kpi">
        <div class="label">الطلاب المسجّلين</div>
        <div class="value">TotalStudents</div>
        <div class="delta up">▲StudentsGrowthPercent% هذا الشهر</div>
    </div>
    <div class="kpi">
        <div class="label">إيرادات الشهر</div>
        <div class="value">MonthlyRevenue ج.م</div>
        <div class="delta down">RevenueChangePercent% عن الشهر الماضي</div>
    </div>
</div>

<div class="admin-grid">

    <!-- Activity / approval log -->
    <section class="panel">
        <div class="panel-heading">
            <h3>سجل النشاط الأخير</h3>
            <a href="#" class="view-all">عرض الكل</a>
        </div>

        <table class="registry-log" id="activity-log">
            <thead>
                <tr>
                    <th>الدورة</th>
                    <th>المدرّس</th>
                    <th>التاريخ</th>
                    <th>الحالة</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @* @foreach (var item in Model.RecentSubmissions)
                {
                    <tr>
                        <td>@item.CourseTitle</td>
                        <td>@item.InstructorName</td>
                        <td class="mono-cell">@item.SubmittedOn.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="status-pill @item.StatusCssClass">@item.StatusLabel</span>
                        </td>
                        <td>
                            @if (item.StatusCssClass == "pending")
                            {
                                <button data-action="approve" title="اعتماد">✔</button>
                                <button data-action="reject" title="رفض">✕</button>
                            }
                            else
                            {
                                <button data-action="view" title="عرض">↗</button>
                            }
                        </td>
                    </tr>
                } *@
            </tbody>
        </table>
    </section>

    <!-- Right column: system health + quick actions -->
    <div style="display:flex; flex-direction:column; gap:24px;">

        <section class="panel">
            <div class="panel-heading">
                <h3>صحة النظام</h3>
            </div>

            <div class="health-item">
                <div class="row"><span>استخدام الخادم</span><span class="val">ServerLoadPercent%</span></div>
                <div class="health-bar"><div class="fill" style="width:10%"></div></div>
            </div>
            <div class="health-item">
                <div class="row"><span>مساحة التخزين</span><span class="val">%</span></div>
                <div class="health-bar"><div class="fill warn" style="width:10%"></div></div>
            </div>
            <div class="health-item">
                <div class="row"><span>معدّل الأخطاء</span><span class="val">%</span></div>
                <div class="health-bar"><div class="fill crit" style="width:10%"></div></div>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <h3>إجراءات سريعة</h3>
            </div>
            <div class="quick-actions">
                <button data-quick-action="تصدير تقرير الشهر">
                    تصدير تقرير الشهر <span>↓</span>
                </button>
                <button data-quick-action="مسح الذاكرة المؤقتة">
                    مسح الذاكرة المؤقتة <span>⟳</span>
                </button>
                <button data-quick-action="إرسال إشعار عام">
                    إرسال إشعار عام <span>➜</span>
                </button>
            </div>
        </section>

    </div>
</div>

@section Scripts {
    <script src="~/js/admin-dashboard.js"></script>
}
