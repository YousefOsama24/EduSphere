@model Subscription
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Create new Subscription</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="Name" class="form-label">SubscriptionId</label>
                    <input class="form-control" placeholder="SubscriptionId" asp-for="SubscriptionId">
                    <span asp-validation-for="SubscriptionId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">CenterId</label>
                    <input class="form-control" placeholder="CenterId" asp-for="CenterId">
                    <span asp-validation-for="CenterId" class="text-danger"></span>
                    
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">SubscriptionPlanId</label>
                    <input class="form-control" placeholder="SubscriptionPlanId" asp-for="SubscriptionPlanId">
                    <span asp-validation-for="SubscriptionPlanId" class="text-danger"></span>
                    
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">StartDate</label>
                    <input class="form-control" placeholder="StartDate" asp-for="StartDate">
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                    
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">EndDate</label>
                    <input class="form-control" placeholder="EndDate" asp-for="EndDate">
                    <span asp-validation-for="EndDate" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Status</label>
                    <input class="form-control" placeholder="Status" asp-for="Status">
                    <span asp-validation-for="Status" class="text-danger"></span>

                </div>
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>