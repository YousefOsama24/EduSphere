@model Choice
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Create new Choice</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="Name" class="form-label">ChoiceId</label>
                    <input class="form-control" placeholder="ChoiceId" asp-for="ChoiceId">
                    <span asp-validation-for="ChoiceId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">QuestionId</label>
                    <input class="form-control" placeholder="QuestionId" asp-for="QuestionId">
                    <span asp-validation-for="QuestionId" class="text-danger"></span>
                    
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Content</label>
                    <input class="form-control" placeholder="Content" asp-for="Content">
                    <span asp-validation-for="Content" class="text-danger"></span>
                    
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">IsCorrect</label>
                    <input class="form-control" placeholder="IsCorrect" asp-for="IsCorrect">
                    <span asp-validation-for="IsCorrect" class="text-danger"></span>
                    
                </div>
                
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>