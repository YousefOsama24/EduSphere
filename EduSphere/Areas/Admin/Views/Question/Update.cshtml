@model Question

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Question</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <!-- Ensure the Edit form posts the id -->
              
                <div class="mb-3">
                    <label for="Name" class="form-label">QuestionId</label>
                    <input class="form-control" placeholder="QuestionId" asp-for="QuestionId">
                    <span asp-validation-for="QuestionId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">ExamId</label>
                    <input class="form-control" placeholder="ExamId" asp-for="ExamId">
                    <span asp-validation-for="ExamId" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Content</label>
                    <input class="form-control" placeholder="Content" asp-for="Content">
                    <span asp-validation-for="Content" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Type</label>
                    <input class="form-control" placeholder="Type" asp-for="Type">
                    <span asp-validation-for="Type" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Marks</label>
                    <input class="form-control" placeholder="Marks" asp-for="Marks">
                    <span asp-validation-for="Marks" class="text-danger"></span>

                </div>
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

