@model Payment

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Payment</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <!-- Ensure the Edit form posts the id -->
                
               @*  <div class="mb-3">
                    <label for="Name" class="form-label">PaymentId</label>
                    <input class="form-control" placeholder="PaymentId" asp-for="PaymentId">
                    <span asp-validation-for="PaymentId" class="text-danger"></span>
                </div>  *@
                <div class="mb-3">
                    <label for="Name" class="form-label">SubscriptionId</label>
                    <input class="form-control" placeholder=SubscriptionId" asp-for="SubscriptionId">
                    <span asp-validation-for="SubscriptionId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Amount</label>
                    <input class="form-control" placeholder="Amount" asp-for="Amount">
                    <span asp-validation-for="Amount" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">PaymentMethod</label>
                    <input class="form-control" placeholder="PaymentMethod" asp-for="PaymentMethod">
                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Status</label>
                    <input class="form-control" placeholder="Status" asp-for="Status">
                    <span asp-validation-for="Status" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">TransactionReference</label>
                    <input class="form-control" placeholder="TransactionReference" asp-for="TransactionReference">
                    <span asp-validation-for="TransactionReference" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">PaymentDate</label>
                    <input class="form-control" placeholder="PaymentDate" asp-for="PaymentDate">
                    <span asp-validation-for="PaymentDate" class="text-danger"></span>

                </div>
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

