@model Parent
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Create new Parent</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="Name" class="form-label">Name</label>
                    <input class="form-control" placeholder="Name" asp-for="User.FullName">
                    <span asp-validation-for="User.FullName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Occupation</label>
                    <input class="form-control" placeholder="Occupation" asp-for="Occupation">
                    <span asp-validation-for="Occupation" class="text-danger"></span>
                    
                </div>
                
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>