@model StudentAnswer

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update StudentAnswer</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <!-- Ensure the Edit form posts the id -->
                <div class="mb-3">
                    <label for="Name" class="form-label">StudentAnswerId</label>
                    <input class="form-control" placeholder="StudentAnswerId" asp-for="StudentAnswerId">
                    <span asp-validation-for="StudentAnswerId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">ExamAttemptId</label>
                    <input class="form-control" placeholder="ExamAttemptId" asp-for="ExamAttemptId">
                    <span asp-validation-for="ExamAttemptId" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">QuestionId</label>
                    <input class="form-control" placeholder="QuestionId" asp-for="QuestionId">
                    <span asp-validation-for="QuestionId" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">SelectedChoiceId</label>
                    <input class="form-control" placeholder="SelectedChoiceId" asp-for="SelectedChoiceId">
                    <span asp-validation-for="SelectedChoiceId" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">EssayAnswer</label>
                    <input class="form-control" placeholder="EssayAnswer" asp-for="EssayAnswer">
                    <span asp-validation-for="EssayAnswer" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">MarksAwarded</label>
                    <input class="form-control" placeholder="MarksAwarded" asp-for="MarksAwarded">
                    <span asp-validation-for="MarksAwarded" class="text-danger"></span>

                </div>
                
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

