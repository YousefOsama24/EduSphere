@model Center

<div class="container my-4">
    <!-- عنوان الصفحة -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold text-dark"><i class="fa-solid fa-pen-to-square text-warning me-2"></i> تعديل بيانات السنتر</h2>
            <p class="text-muted mb-0">تحديث معلومات سنتر: **@Model.Name**</p>
        </div>
    </div>

    <!-- كارت الفورم -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4">
            <form asp-controller="Center" asp-action="Update" method="post" enctype="multipart/form-data">

                <!-- حقول مخفية مهمة جداً عشان الأنبوتس القديمة متبوظش في الـ Post -->
                <input type="hidden" asp-for="CenterId" />
                <input type="hidden" asp-for="LogoUrl" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="IsDeleted" />
                
                <div class="row">
                    <!-- العمود الأيمن: البيانات الأساسية -->
                    <div class="col-lg-8">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">CenterName</label>
                                <input class="form-control form-control-lg" placeholder="CenterName" asp-for="Name">
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                <input type="email" class="form-control form-control-lg" placeholder="Email" asp-for="Email">
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone</label>
                                <input class="form-control form-control-lg" placeholder="Phone" asp-for="Phone">
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Address" class="form-label fw-semibold">Address</label>
                                <input class="form-control form-control-lg" placeholder="Address" asp-for="Address">
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Description" class="form-label fw-semibold">Description</label>
                                <textarea class="form-control" rows="3" placeholder="Description" asp-for="Description"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <!-- العمود الأيسر: عرض اللوجو الحالي وتحديثه -->
                    <div class="col-lg-4 border-start-lg mb-3">
                        <div class="d-flex flex-column align-items-center text-center p-2">
                            <label class="form-label fw-semibold mb-3">شعار السنتر الحالي (Logo)</label>

                            <!-- هنا بنعرض اللوجو القديم، ولو مفيش بنحط صورة الـ Placeholder -->
                            <div class="mb-3 position-relative">
                                <img id="logoPreview" src="@(string.IsNullOrEmpty(Model.LogoUrl) ? "https://via.placeholder.com/150?text=No+Logo" : Model.LogoUrl)"
                                     alt="Logo Preview"
                                     class="img-thumbnail rounded-circle shadow-sm"
                                     style="width: 150px; height: 150px; object-fit: cover;">
                            </div>

                            <!-- إنبوت رفع صورة جديدة لو الأدمن حابب يغيرها -->
                            <div class="w-100 px-3">
                                <input type="file" name="LogoFile" id="logoInput" class="form-control" accept="image/*" onchange="previewImage(event)">
                                <small class="text-muted d-block mt-2">اسحب أو اختر صورة جديدة لتحديث اللوجو الحالي</small>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="text-muted my-4">

                <!-- أزرار التحكم -->
                <div class="d-flex justify-content-end gap-2">
                    <a href="/SuperAdmin/Center/Index" class="btn btn-light px-4">إلغاء</a>
                    <button type="submit" class="btn btn-warning px-5 fw-semibold text-white">
                        <i class="fa-solid fa-pen-to-square me-1"></i> تحديث البيانات
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- كود الـ JavaScript لمعاينة الصورة الجديدة فوراً لو الأدمن اختار ملف جديد -->
<script>
    function previewImage(event) {
        var reader = new FileReader();
        reader.onload = function () {
            var output = document.getElementById('logoPreview');
            output.src = reader.result;
        }
        if(event.target.files[0]) {
            reader.readAsDataURL(event.target.files[0]);
        }
    }
</script>