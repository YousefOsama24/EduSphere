@model Center

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Center</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <!-- Ensure the Edit form posts the id -->
                <input type="hidden" asp-for="CenterId" />
               @*  <div class="mb-3">
                    <label for="Name" class="form-label">CenterId</label>
                    <input class="form-control" placeholder="CenterId" asp-for="CenterId">
                    <span asp-validation-for="CenterId" class="text-danger"></span>
                </div> *@
                <div class="mb-3">
                    <label for="Name" class="form-label">Name</label>
                    <input class="form-control" placeholder="Name" asp-for="Name">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Description</label>
                    <input class="form-control" placeholder="Description" asp-for="Description">
                    <span asp-validation-for="Description" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Email</label>
                    <input class="form-control" placeholder="Email" asp-for="Email">
                    <span asp-validation-for="Email" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Address</label>
                    <input class="form-control" placeholder="Address" asp-for="Address">
                    <span asp-validation-for="Address" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Phone</label>
                    <input class="form-control" placeholder="Phone" asp-for="Phone">
                    <span asp-validation-for="Phone" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">LogoUrl</label>
                    <input class="form-control" placeholder="LogoUrl" asp-for="LogoUrl">
                    <span asp-validation-for="LogoUrl" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">CreatedAt</label>
                    <input class="form-control" placeholder="CreatedAt" asp-for="CreatedAt">
                    <span asp-validation-for="CreatedAt" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">UpdatedAt</label>
                    <input class="form-control" placeholder="UpdatedAt" asp-for="UpdatedAt">
                    <span asp-validation-for="UpdatedAt" class="text-danger"></span>

                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="IsDeleted" />
                    <label class="form-check-label" asp-for="IsDeleted"></label>
                </div>
               
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

