@using EduSphere.ViewModel;
@model CentersVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">All Centers</h2>
        </div>
        @*if (User.IsInRole(SD.SUPER_ADMIN_ROLE) || User.IsInRole(SD.ADMIN_ROLE))
        {*@
            <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
                <a href="/SuperAdmin/Center/Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create</a>
            </div>
        @* } *@
    </div>

    <!-- Filter Section -->
    <section class="py-3 filter-bar">
        <div class="container">
            <div class="row" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
                <div class="col-12">
                    <form method="get" action="/SuperAdmin/Center/Index">
                        <div class="row align-items-center">
                            <!-- Center Name -->
                            <div class="col-md-3">
                                <input type="text" class="form-control" placeholder="Search by Name..." name="query" value="@ViewBag.Query">
                            </div>

                            <!-- Submit & Reset Buttons -->
                            <div class="col-md-4 d-flex gap-2">
                                <button type="submit" class="btn btn-dark w-50">Filter</button>
                                @if (!string.IsNullOrEmpty(ViewBag.Query))
                                {
                                    <a href="/SuperAdmin/Center/Index" class="btn btn-outline-secondary w-50">Clear</a>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Data Table -->
    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Logo</th>
                            <th scope="col">Name</th>
                            <th scope="col">Description</th>
                            <th scope="col">Email</th>
                            <th scope="col">Address</th>
                            <th scope="col">Phone</th>
                            <th scope="col">Status</th>
                            <th scope="col" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Centers != null && Model.Centers.Any())
                        {
                            @foreach (var item in Model.Centers)
                            {
                                <tr>
                                    <th scope="row">@item.CenterId</th>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.LogoUrl))
                                        {
                                            <img src="@item.LogoUrl" alt="@item.Name Logo" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px; font-size: 12px;">
                                                No Logo
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold">@item.Name</td>
                                    <td>@item.Description</td>
                                    <td>@item.Email</td>
                                    <td>@item.Address</td>
                                    <td>@item.Phone</td>
                                    <td>
                                        @if (item.IsDeleted)
                                        {
                                            <span class="badge bg-danger">Deleted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a href="/SuperAdmin/Center/Update/@item.CenterId" class="btn btn-sm btn-warning">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </a>
                                            
                                            <!-- تعديل كود الحذف عشان يشتغل مع الـ SweetAlert2 الجافاسكريبت اللي تحت بشكل صحيح -->
                                            <button type="button" class="btn btn-sm btn-danger btn-delete" data-id="@item.CenterId">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>

                                            <!-- الفورم المخفية اللي الجافاسكريبت هيعملها Submit بعد الـ Confirm -->
                                            <form id="delete-form-@item.CenterId" action="/SuperAdmin/Center/Delete/@item.CenterId" method="post" style="display:none"></form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4 text-muted">No centers found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination Section -->
    <div class="row mt-3">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/SuperAdmin/Center/Index?page=@(Model.CurrentPage - 1)&query=@ViewBag.Query">Previous</a>
                        </li>
                    }
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/SuperAdmin/Center/Index?page=@i&query=@ViewBag.Query">@i</a>
                        </li>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/SuperAdmin/Center/Index?page=@(Model.CurrentPage + 1)&query=@ViewBag.Query">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- SweetAlert2 JavaScript Setup -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function () {
                const centerId = this.getAttribute("data-id");
                const form = document.getElementById(`delete-form-${centerId}`);

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        // بنعمل Submit للفورم المخفية وبتبعت الـ POST بشكل آمن ودستوري
                        form.submit();
                    }
                });
            });
        });
    });
</script>