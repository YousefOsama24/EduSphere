@model EduSphere.ViewModel.SuperAdminDashboardVM

@{
    ViewData["Title"] = "Super Admin Dashboard";
}

<div class="container-fluid py-4" dir="rtl">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold">لوحة تحكم النظام (Super Admin)</h1>
            <p class="text-muted small mb-0">نظرة عامة على المدرسين، السناتر، عمليات الدفع والتنبيهات.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Center" asp-action="Index" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-building me-1"></i> إدارات السناتر
            </a>
            <a asp-controller="Teacher" asp-action="Index" class="btn btn-primary btn-sm">
                <i class="bi bi-person-badge me-1"></i> إدارة المدرسين
            </a>
        </div>
    </div>

    <!-- 1. Stats Cards Row -->
    <div class="row g-4 mb-4">

        <!-- Total Centers Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-primary">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold small text-uppercase">إجمالي السناتر</span>
                            <h2 class="display-6 fw-bold text-primary mb-0 mt-2">@Model.TotalCenters</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                            <i class="bi bi-building fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Teachers Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-success">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold small text-uppercase">إجمالي المدرسين</span>
                            <h2 class="display-6 fw-bold text-success mb-0 mt-2">@Model.TotalTeachers</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                            <i class="bi bi-person-video3 fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Students Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-info">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold small text-uppercase">الطلاب النشطين</span>
                            <h2 class="display-6 fw-bold text-info mb-0 mt-2">@Model.TotalStudents</h2>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                            <i class="bi bi-people-fill fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Revenue Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-warning">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold small text-uppercase">إجمالي الإيرادات</span>
                            <h2 class="display-6 fw-bold text-warning mb-0 mt-2">@Model.TotalRevenue.ToString("N0") <small class="fs-6">ج.م</small></h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                            <i class="bi bi-cash-stack fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- 2. Tables & Activity Section -->
    <div class="row g-4">

        <!-- Payments Table Section -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-credit-card-2-front me-2 text-primary"></i>آخر عمليات الدفع</h5>
                    <a href="#" class="btn btn-link btn-sm text-decoration-none">عرض الكل</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>رقم العملية</th>
                                    <th>الجهة / الاسم</th>
                                    <th>المبلغ</th>
                                    <th>التاريخ</th>
                                    <th>الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pay in Model.RecentPayments)
                                {
                                    <tr>
                                        <td class="fw-bold">#@pay.PaymentId</td>
                                        <td>@pay.UserOrCenterName</td>
                                        <td class="text-success fw-bold">@pay.Amount.ToString("N2") ج.م</td>
                                        <td class="text-muted small">@pay.Date.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            @if (pay.Status == "Success")
                                            {
                                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">مكتملة</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill">قيد الانتظار</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications & System Logs -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-bell me-2 text-warning"></i>التنبيهات والأحداث</h5>
                    <span class="badge bg-danger rounded-pill">@Model.Notifications.Count() جديدة</span>
                </div>
                <div class="card-body p-3">
                    <div class="d-flex flex-column gap-3">
                        @foreach (var note in Model.Notifications)
                        {
                            <div class="p-3 rounded-3 bg-light border-start border-3 border-@(note.Type == "success" ? "success" : note.Type == "warning" ? "warning" : "info")">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="text-dark small">@note.Title</strong>
                                    <span class="text-muted extra-small" style="font-size: 0.75rem;">@note.CreatedAt.ToString("hh:mm tt")</span>
                                </div>
                                <p class="text-secondary small mb-0">@note.Message</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>