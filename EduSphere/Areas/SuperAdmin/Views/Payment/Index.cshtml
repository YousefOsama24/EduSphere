@using EduSphere.ViewModel;
@model PaymentsVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">All Payments</h2>
        </div>
        @*if (User.IsInRole(SD.SUPER_ADMIN_ROLE) || User.IsInRole(SD.ADMIN_ROLE))
        {*@
            <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
                <a href="/Admin/Payment/Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create</a>
            </div>
        @* } *@
    </div>

    <!-- Filter Section -->
    <section class="py-3 filter-bar">
        <div class="container">
            <div class="row" style="background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;">
                <div class="col-12">
                    <form>
                        <div class="row">
                            <!-- Payment Name -->
                            <div class="col-md-3">
                                <input type="text" class="form-control" placeholder="Name" name="query" value="@ViewBag.Query">
                            </div>

                            <!-- Submit Button -->
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-dark w-100">Filter</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <div class="row">
        <div class="col-12">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th scope="col">PaymentId</th>
                        <th scope="col">SubscriptionId</th>
                        <th scope="col">Amount</th>
                        <th scope="col">PaymentMethod</th>
                        <th scope="col">Status</th>
                        <th scope="col">TransactionReference</th>
                        <th scope="col">PaymentDate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Payments)
                    {
                        <tr>
                            <th scope="row">@item.PaymentId</th>
                            <td>@item.SubscriptionId</td>
                            <td>@item.Amount</td>
                            <td>@item.PaymentMethod</td>
                            <td>@item.Status</td>
                            <td>@item.TransactionReference</td>
                            <td>@item.PaymentDate</td>
 
                            <td>
                                <a href="/Admin/Payment/Update/@item.PaymentId" type="button" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Edit</a>
                                <form asp-action="Delete"
                                      asp-route-id="@item.PaymentId"
                                      method="post"
                                      style="display:inline">

                                    <button type="submit" class="btn btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this choice?')">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                               @* @if (User.IsInRole(SD.SUPER_ADMIN_ROLE) || User.IsInRole(SD.ADMIN_ROLE))
                                {
                                   
                                }
                                else
                                {
                                    <span>NoAction</span>
                                }*@
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Payment/Index?page=@(Model.CurrentPage - 1)">Previous</a></li>
                    }
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.CurrentPage)
                        {
                            <li class="page-item active"><a class="page-link" href="/Admin/Payment/Index?page=@i">@i</a></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="/Admin/Payment/Index?page=@i">@i</a></li>
                        }
                    }
                    @if (Model.CurrentPage != Model.TotalPages)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Payment/Index?page=@(Model.CurrentPage + 1)">Next</a></li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault(); // stop normal navigation

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                          title: "Deleted!",
                          text: "Your file has been deleted.",
                          icon: "success"
                        });

                        // Redirect to delete URL
                        window.location.href = url;
                    }
                });
            });
        });
    });
</script>

