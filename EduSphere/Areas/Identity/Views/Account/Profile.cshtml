@model EduSphere.Areas.Identity.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">

    <div class="col-lg-9">

        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-body p-5">

                <h3 class="mb-4">

                    <i class="bi bi-person-circle me-2"></i>

                    My Profile

                </h3>
                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      method="post">

                    <button class="btn btn-danger">
                        Logout
                    </button>

                </form>
                <form asp-action="Profile"
                      method="post"
                      enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    <input asp-for="UserId" hidden />

                    <input asp-for="CurrentProfileImage" hidden />

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger">
                    </div>

                    <div class="text-center mb-4">

                        @if (!string.IsNullOrEmpty(Model.CurrentProfileImage))
                        {
                            <img src="~/images/profiles/@Model.CurrentProfileImage"
                                 class="rounded-circle shadow"
                                 width="150"
                                 height="150"
                                 style="object-fit:cover;" />
                        }
                        else
                        {
                            <img src="~/images/default-user.png"
                                 class="rounded-circle shadow"
                                 width="150"
                                 height="150"
                                 style="object-fit:cover;" />
                        }

                    </div>

                   

                    <div class="mb-4">

                        <label asp-for="ProfileImage"
                               class="form-label fw-bold"></label>

                        <input asp-for="ProfileImage"
                               class="form-control" />

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="FullName"></label>

                            <input asp-for="FullName"
                                   class="form-control" />

                            <span asp-validation-for="FullName"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="Email"></label>

                            <input asp-for="Email"
                                   class="form-control"
                                   readonly />

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="PhoneNumber"></label>

                            <input asp-for="PhoneNumber"
                                   class="form-control" />

                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label>User Type</label>

                            <input class="form-control"
                                   value="@Model.UserType"
                                   readonly />

                        </div>

                        <div class="col-md-6">

                            <label>Account Created</label>

                            <input class="form-control"
                                   value="@Model.CreatedAt.ToString("dd MMM yyyy")"
                                   readonly />

                        </div>

                    </div>

                    <div class="d-grid mt-4">

                        <button class="btn btn-success btn-auth">

                            <i class="bi bi-floppy-fill me-2"></i>

                            Save Changes

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}