@model EduSphere.Areas.Identity.ViewModels.ForgotPasswordViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<EduSphere.SharedResource> Localizer
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="text-center mb-5">

            <div class="display-4 text-warning mb-3">

                <i class="bi bi-key-fill"></i>

            </div>

            <h2 class="page-title">

                @Localizer["Forgot Password"]

            </h2>

            <p class="page-subtitle">

                @Localizer["Enter your email address and we'll send you a password reset link."]

            </p>

        </div>

        <form asp-action="ForgotPassword"
              method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <div class="input-wrapper">

                <span class="input-group-text">

                    <i class="bi bi-envelope-fill"></i>

                </span>

                <input asp-for="Email"
                       class="form-control"
                       placeholder="@Localizer["Email Address"]" />

                <span asp-validation-for="Email"
                      class="text-danger small">
                </span>

            </div>

            <div class="d-grid mt-4">

                <button type="submit"
                        class="btn btn-warning btn-auth">

                    <i class="bi bi-send-fill me-2"></i>

                    @Localizer["Send Reset Link"]

                </button>

            </div>

            <hr class="my-4" />

            <div class="text-center">

                <a asp-action="Login"
                       class="auth-link">

                    <i class="bi bi-arrow-left me-1"></i>

                    @Localizer["Back To Login"]

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}