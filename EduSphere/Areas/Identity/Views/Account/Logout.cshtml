@inject Microsoft.Extensions.Localization.IStringLocalizer<EduSphere.SharedResource> Localizer
@{
    ViewData["Title"] ="Logout";
}

<div class="container mt-5">

    <div class="card shadow-sm">

        <div class="card-body text-center">

            <h2 class="text-danger mb-4">
                @Localizer["Logout"]
            </h2>

            <p class="lead">
                @Localizer["Are you sure you want to log out?"] 
            </p>

            <form asp-area="Identity"
                  asp-controller="Account"
                  asp-action="Logout"
                  method="post">

                @Html.AntiForgeryToken()

                <button type="submit"
                        class="btn btn-danger me-2">

                    <i class="bi bi-box-arrow-right"></i>

                    @Localizer["Logout"]

                </button>

                <a asp-action="RedirectToDashboard"
                       class="btn btn-secondary">

                    @Localizer["Cancel"]

                </a>

            </form>

        </div>

    </div>

</div>
