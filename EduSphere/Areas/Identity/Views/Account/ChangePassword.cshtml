@model EduSphere.Areas.Identity.ViewModels.ChangePasswordViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<EduSphere.SharedResource> Localizer
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="text-center mb-5">

            <div class="display-4 text-primary mb-3">

                <i class="bi bi-key-fill"></i>

            </div>

            <h2 class="page-title">

                Change Password

                @Localizer["Change Password"]
            </h2>

            <p class="page-subtitle">

                Update your account password.
                @Localizer["Update your account password."]

            </p>

        </div>

        <form asp-action="ChangePassword"
              method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <!-- Current Password -->

            <div class="input-wrapper">

                <span class="input-group-text">

                    <i class="bi bi-lock-fill"></i>

                </span>

                <input asp-for="CurrentPassword"
                       id="CurrentPassword"
                       class="form-control"
                       placeholder="Current Password" />
                placeholder="@Localizer["Current Password"]" />

                <i class="bi bi-eye toggle-password password-toggle"
                   data-target="CurrentPassword"></i>

                <span asp-validation-for="CurrentPassword"
                      class="text-danger small">
                </span>

            </div>

            <!-- New Password -->

            <div class="input-wrapper">

                <span class="input-group-text">

                    <i class="bi bi-shield-lock-fill"></i>

                </span>

                <input asp-for="NewPassword"
                       id="NewPassword"
                       class="form-control"
                       placeholder="New Password" />

                <i class="bi bi-eye toggle-password password-toggle"
                   data-target="NewPassword"></i>
                placeholder="@Localizer["New Password"]" />

                <span asp-validation-for="NewPassword"
                      class="text-danger small">
                </span>

            </div>

            <!-- Confirm Password -->

            <div class="input-wrapper">

                <span class="input-group-text">

                    <i class="bi bi-check2-circle"></i>

                </span>

                <input asp-for="ConfirmPassword"
                       id="ConfirmPassword"
                       class="form-control"
                       placeholder="Confirm Password" />
                placeholder="@Localizer["Confirm Password"]" />

                <i class="bi bi-eye toggle-password password-toggle"
                   data-target="ConfirmPassword"></i>

                <span asp-validation-for="ConfirmPassword"
                      class="text-danger small">
                </span>

            </div>

            <div class="d-grid mt-4">

                <button type="submit"
                        class="btn btn-primary btn-auth">

                    <i class="bi bi-check-circle-fill me-2"></i>

                    Change Password

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}