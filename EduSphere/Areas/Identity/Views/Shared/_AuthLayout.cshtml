<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - EduSphere</title>

    <link rel="icon"
          type="image/png"
          href="~/favicon.png" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{

            min-height:100vh;

            display:flex;

            justify-content:center;

            align-items:center;

            font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;

            background:
            linear-gradient(135deg,#0d6efd,#4f46e5);

            overflow-x:hidden;
        }

        .background-circle{

            position:absolute;

            border-radius:50%;

            filter:blur(70px);

            opacity:.25;

        }

        .circle-1{

            width:300px;

            height:300px;

            background:#ffffff;

            top:-100px;

            left:-100px;
        }

        .circle-2{

            width:350px;

            height:350px;

            background:#7dd3fc;

            bottom:-150px;

            right:-120px;
        }

        .auth-wrapper{

            width:100%;

            max-width:1150px;

            padding:30px;
        }

        .auth-card{

            border:none;

            border-radius:24px;

            overflow:hidden;

            box-shadow:
            0 20px 50px rgba(0,0,0,.18);
        }

        .left-panel{

            background:
            linear-gradient(160deg,#0d6efd,#4338ca);

            color:white;

            padding:70px 55px;

            display:flex;

            flex-direction:column;

            justify-content:center;

            min-height:700px;
        }

        .left-panel h1{

            font-size:42px;

            font-weight:700;

            margin-bottom:20px;
        }

        .left-panel p{

            opacity:.9;

            line-height:1.8;
        }

        .logo{

            width:90px;

            height:90px;

            border-radius:18px;

            background:white;

            color:#0d6efd;

            display:flex;

            justify-content:center;

            align-items:center;

            font-size:42px;

            margin-bottom:35px;
        }

        .right-panel{

            background:white;

            padding:60px;
        }

        .page-title{

            font-weight:700;

            margin-bottom:10px;
        }

        .page-subtitle{

            color:#6c757d;

            margin-bottom:35px;
        }
        .form-control{

            height:52px;

            border-radius:12px;

            padding-left:45px;

            border:1px solid #dcdcdc;
        }

        .form-control:focus{

            box-shadow:none;

            border-color:#0d6efd;
        }

        .input-group-text{

            position:absolute;

            z-index:10;

            height:52px;

            background:transparent;

            border:none;

            color:#6c757d;

            width:45px;

            justify-content:center;
        }

        .input-wrapper{

            position:relative;

            margin-bottom:22px;
        }

        .btn-auth{

            height:52px;

            border-radius:12px;

            font-weight:600;

            font-size:16px;
        }

        .auth-link{

            text-decoration:none;

            font-weight:600;
        }

        .auth-link:hover{

            text-decoration:underline;
        }

        .password-toggle{

            position:absolute;

            right:15px;

            top:50%;

            transform:translateY(-50%);

            cursor:pointer;

            color:#6c757d;

            z-index:20;
        }

        .validation-summary-errors ul{

            list-style:none;

            padding:0;

            margin:0;
        }

        footer{

            margin-top:40px;

            text-align:center;

            color:#adb5bd;

            font-size:14px;
        }

        @@media(max-width:992px){

            .left-panel{

                display:none;
            }

            .right-panel{

                padding:40px;
            }

        }

        @@media(max-width:576px){

            .auth-wrapper{

                padding:10px;
            }

            .right-panel{

                padding:30px 20px;
            }

        }

    </style>

</head>

<body>

    <div class="background-circle circle-1"></div>

    <div class="background-circle circle-2"></div>

    <div class="container auth-wrapper">

        <div class="card auth-card">

            <div class="row g-0">

                <div class="col-lg-5">

                    <div class="left-panel">

                        <div class="logo">

                            <i class="bi bi-mortarboard-fill"></i>

                        </div>

                        <h1>EduSphere</h1>

                        <p>

                            Smart Educational Management Platform
                            for Centers, Teachers, Students and Parents.

                        </p>

                        <hr class="my-4"/>

                        <h5>Features</h5>

                        <ul class="mt-3">

                            <li>Course Management</li>

                            <li>Online Exams</li>

                            <li>Attendance System</li>

                            <li>Assignments</li>

                            <li>Payments</li>

                            <li>Notifications</li>

                        </ul>

                    </div>

                </div>

                <div class="col-lg-7">

                    <div class="right-panel">
                                                @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show">

                                <i class="bi bi-check-circle-fill me-2"></i>

                                @TempData["Success"]

                                <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="alert">
                                </button>

                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show">

                                <i class="bi bi-exclamation-triangle-fill me-2"></i>

                                @TempData["Error"]

                                <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="alert">
                                </button>

                            </div>
                        }

                        @RenderBody()

                        <footer>

                            © @DateTime.Now.Year
                            EduSphere Educational Management Platform

                        </footer>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_ValidationScriptsPartial")

    @await RenderSectionAsync("Scripts", required: false)

    <script>

        // Show / Hide Password

        document.querySelectorAll(".toggle-password").forEach(button => {

            button.addEventListener("click", function () {

                let input = document.getElementById(
                    this.getAttribute("data-target"));

                if (!input)
                    return;

                if (input.type === "password") {

                    input.type = "text";

                    this.classList.remove("bi-eye");

                    this.classList.add("bi-eye-slash");
                }
                else {

                    input.type = "password";

                    this.classList.remove("bi-eye-slash");

                    this.classList.add("bi-eye");
                }

            });

        });

        // Loading Button

        document.querySelectorAll("form").forEach(form => {

            form.addEventListener("submit", function () {

                let btn = form.querySelector("button[type='submit']");

                if (btn) {

                    btn.disabled = true;

                    btn.innerHTML =
                        "<span class='spinner-border spinner-border-sm me-2'></span>Please wait...";

                }

            });

        });

    </script>

</body>

</html>