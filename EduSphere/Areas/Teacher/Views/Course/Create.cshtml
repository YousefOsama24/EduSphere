@model EduSphere.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- زر الرجوع -->
            <div class="d-flex align-items-center gap-2 mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                    <i class="bi bi-arrow-left d-flex"></i>
                </a>
                <span class="text-muted">Back to List</span>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0">Create New Course Track</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- التواريخ الافتراضية للإنشاء -->
                        <input type="hidden" asp-for="CreatedAt" value="@DateTime.Now" />
                        <input type="hidden" asp-for="UpdatedAt" value="@DateTime.Now" />

                        <div class="row g-3">
                            <!-- اسم الكورس -->
                            <div class="col-md-12">
                                <label asp-for="Title" class="form-label fw-semibold">Course Title</label>
                                <input asp-for="Title" class="form-control" placeholder="e.g. Physics Secondary 3" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <!-- معرف المركز التعليمي -->
                            <div class="col-md-6">
                                <label asp-for="CenterId" class="form-label fw-semibold">Center ID</label>
                                <input asp-for="CenterId" type="number" class="form-control" placeholder="Enter Center ID" />
                                <span asp-validation-for="CenterId" class="text-danger small"></span>
                            </div>

                            <!-- معرف المدرس المسؤول -->
                            <div class="col-md-6">
                                <label asp-for="TeacherId" class="form-label fw-semibold">Teacher ID</label>
                                <input asp-for="TeacherId" type="number" class="form-control" placeholder="Enter Your Teacher ID" />
                                <span asp-validation-for="TeacherId" class="text-danger small"></span>
                            </div>

                            <!-- السعر -->
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-semibold">Price</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <!-- حالة النشر -->
                            <div class="col-md-6 d-flex align-items-end mb-2">
                                <div class="form-check form-switch card p-2 px-4 w-100 border shadow-none bg-light mb-0">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" asp-for="IsPublished" id="publishSwitch">
                                    <label class="form-check-label fw-semibold" for="publishSwitch">Publish Immediately</label>
                                </div>
                            </div>

                            <!-- رابط صورة الغلاف -->
                            <div class="col-md-12">
                                <label asp-for="ThumbnailUrl" class="form-label fw-semibold">Thumbnail Cover Image URL</label>
                                <input asp-for="ThumbnailUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                                <span asp-validation-for="ThumbnailUrl" class="text-danger small"></span>
                            </div>

                            <!-- وصف ومحتوى الكورس -->
                            <div class="col-md-12">
                                <label asp-for="Description" class="form-label fw-semibold">Course Overview / Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Type course requirements and what students will learn..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Save Course</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@* @section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
} *@