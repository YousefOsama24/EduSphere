@model EduSphere.Models.Exam

@{
    ViewData["Title"] = "Create Exam";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- زر الرجوع للقائمة -->
            <div class="d-flex align-items-center gap-2 mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                    <i class="bi bi-arrow-left d-flex"></i>
                </a>
                <span class="text-muted">Back to Exams</span>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-file-earmark-plus me-2"></i>Create New Exam</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <!-- عنوان الامتحان -->
                            <div class="col-md-12">
                                <label asp-for="Title" class="form-label fw-semibold">Exam Title</label>
                                <input asp-for="Title" class="form-control" placeholder="e.g. Chapter 1 Quiz - Thermodynamics" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <!-- معرف الكورس المرتبط به الامتحان -->
                            <div class="col-md-4">
                                <label asp-for="CourseId" class="form-label fw-semibold">Course ID</label>
                                <input asp-for="CourseId" type="number" class="form-control" placeholder="Enter Course ID" />
                                <span asp-validation-for="CourseId" class="text-danger small"></span>
                            </div>

                            <!-- مدة الامتحان بالدقائق -->
                            <div class="col-md-4">
                                <label asp-for="DurationMinutes" class="form-label fw-semibold">Duration (Minutes)</label>
                                <div class="input-group">
                                    <input asp-for="DurationMinutes" type="number" class="form-control" placeholder="60" />
                                    <span class="input-group-text">min</span>
                                </div>
                                <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                            </div>

                            <!-- الدرجة الكلية -->
                            <div class="col-md-4">
                                <label asp-for="TotalMarks" class="form-label fw-semibold">Total Marks</label>
                                <input asp-for="TotalMarks" type="number" step="0.5" class="form-control" placeholder="100" />
                                <span asp-validation-for="TotalMarks" class="text-danger small"></span>
                            </div>

                            <!-- تاريخ ووقت البدء -->
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-semibold">Start Date & Time</label>
                                <input asp-for="StartDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>

                            <!-- تاريخ ووقت الانتهاء -->
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-semibold">End Date & Time</label>
                                <input asp-for="EndDate" type="datetime-local" class="form-control" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>

                            <!-- وصف وتعليمات الامتحان -->
                            <div class="col-md-12">
                                <label asp-for="Description" class="form-label fw-semibold">Instructions / Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter exam rules, instructions, or coverage details..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Create Exam</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

