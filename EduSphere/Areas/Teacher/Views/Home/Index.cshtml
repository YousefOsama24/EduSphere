@model EduSphere.ViewModel.TeacherDashboardVM

@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Teacher Dashboard</h1>
            <p class="text-muted small mb-0">Overview of your academic statistics and activity.</p>
        </div>
        <span class="badge bg-primary px-3 py-2 fs-6">EduSphere Teacher Panel</span>
    </div>

    <!-- Stats Cards Row -->
    <div class="row g-4 mb-4">

        <!-- Total Students Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-primary">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Total Students</span>
                            <h2 class="display-6 fw-bold text-primary mb-0 mt-2">@Model.TotalStudents</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                            <i class="bi bi-people-fill fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Exams Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-success">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Total Exams</span>
                            <h2 class="display-6 fw-bold text-success mb-0 mt-2">@Model.TotalExams</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                            <i class="bi bi-file-earmark-text-fill fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Lectures Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-warning">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Lectures Count</span>
                            <h2 class="display-6 fw-bold text-warning mb-0 mt-2">@Model.TotalLectures</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                            <i class="bi bi-journal-bookmark-fill fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Average Grades / Performance Card -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-info">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Avg. Performance</span>
                            <h2 class="display-6 fw-bold text-info mb-0 mt-2">@Model.AverageGrade%</h2>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                            <i class="bi bi-graph-up-arrow fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Quick Navigation Actions -->
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
                    <span class="fw-semibold text-secondary ms-2">Quick Management:</span>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Question" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-2">
                            <i class="bi bi-question-circle me-1"></i> Questions Bank
                        </a>
                        <a asp-controller="Lecture" asp-action="Index" class="btn btn-outline-warning btn-sm rounded-2">
                            <i class="bi bi-play-circle me-1"></i> Lectures
                        </a>
                        <a asp-controller="Group" asp-action="Index" class="btn btn-outline-success btn-sm rounded-2">
                            <i class="bi bi-people me-1"></i> Groups
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>