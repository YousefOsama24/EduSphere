@model EduSphere.ViewModel.GroupsVM

@{
    ViewData["Title"] = "Groups Management";
}

<div class="container-fluid py-4">
    <!-- إشعار النجاح -->
    @if (TempData["success-notification"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success-notification"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- رأس الصفحة وأزرار التحكم -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Groups</h1>
            <p class="text-muted small mb-0">Manage all educational groups and schedules.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Add New Group
        </a>
    </div>

    <!-- كارت الفلترة والبحث -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group">
                        <input type="text" name="query" value="@ViewBag.Query" class="form-control" placeholder="Search by group name..." />
                        <button class="btn btn-secondary" type="submit">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(ViewBag.Query))
                {
                    <div class="col-auto">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear Filter</a>
                    </div>
                }
            </form>
        </div>
    </div>

    <!-- جدول عرض البيانات -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Group ID</th>
                            <th class="ps-4">Group Name</th>
                            <th>Course</th>
                            <th>Capacity</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Groups != null && Model.Groups.Any())
                        {
                            @foreach (var item in Model.Groups)
                            {
                                <tr>
                                    <td class="fw-bold ps-4">@item.GroupId</td>
                                    <td class="fw-bold ps-4">@item.Name</td>
                                    <td>@(item.Course?.Title ?? "N/A")</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@item.Capacity Students</span>
                                    </td>
                                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Update" asp-route-id="@item.GroupId" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.GroupId" method="post" onsubmit="return confirm('Are you sure you want to delete this group?');" style="display:inline;">
                                                <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x display-4 d-block mb-3"></i>
                                    No groups found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- صفحة التنقل (Pagination) -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="small text-muted">Page @Model.CurrentPage of @Model.TotalPages</span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-item" href="@Url.Action("Index", new { page = i, query = ViewBag.Query })" class="page-link">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>