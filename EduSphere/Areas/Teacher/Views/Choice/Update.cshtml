@model Choice

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Choice</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <!-- Ensure the Edit form posts the id -->
                <input type="hidden" asp-for="ChoiceId" />
                
                <div class="mb-3">
                    <label for="Img" class="form-label">QuestionId</label>
                    <input class="form-control" placeholder="QuestionId" asp-for="QuestionId">
                    <span asp-validation-for="QuestionId" class="text-danger"></span>

                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Content</label>
                    <input class="form-control" placeholder="Content" asp-for="Content">
                    <span asp-validation-for="Content" class="text-danger"></span>

                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="IsCorrect" />
                    <label class="form-check-label" asp-for="IsCorrect"></label>
                </div>

               
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

