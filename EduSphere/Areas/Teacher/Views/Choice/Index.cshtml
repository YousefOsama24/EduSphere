@model EduSphere.ViewModel.ChoicesVM

@{
    ViewData["Title"] = "Choices Management";
}

<div class="container-fluid py-4">
    @if (TempData["success-notification"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success-notification"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Question Choices</h1>
            <p class="text-muted small mb-0">Manage options and answers for quiz questions.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Add New Choice
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group">
                        <input type="text" name="query" value="@ViewBag.Query" class="form-control" placeholder="Search choices content..." />
                        <button class="btn btn-secondary" type="submit">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(ViewBag.Query))
                {
                    <div class="col-auto">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear Filter</a>
                    </div>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th class="ps-4">Choice Content</th>
                            <th>Related Question</th>
                            <th>Is Correct Answer?</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Choices != null && Model.Choices.Any())
                        {
                            @foreach (var item in Model.Choices)
                            {
                                <tr>
                                    <td class="fw-bold ps-4">@item.ChoiceId</td>
                                    <td class="fw-bold ps-4">@item.Content</td>
                                    <td class="text-truncate" style="max-width: 300px;">
                                        @(item.Question?.Content ?? "N/A")
                                    </td>
                                    <td>
                                        @if (item.IsCorrect)
                                        {
                                            <span class="badge bg-success d-inline-flex align-items-center gap-1">
                                                <i class="bi bi-check-lg"></i> Correct
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border">Incorrect</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Update" asp-route-id="@item.ChoiceId" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.ChoiceId" method="post" onsubmit="return confirm('Are you sure you want to delete this choice?');" style="display:inline;">
                                                <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x display-4 d-block mb-3"></i>
                                    No choices found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="small text-muted">Page @Model.CurrentPage of @Model.TotalPages</span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = i, query = ViewBag.Query })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>