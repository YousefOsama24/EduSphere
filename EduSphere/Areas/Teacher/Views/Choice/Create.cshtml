@model EduSphere.Models.Choice

@{
    ViewData["Title"] = "Create Choice";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- زر الرجوع للقائمة -->
            <div class="d-flex align-items-center gap-2 mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                    <i class="bi bi-arrow-left d-flex"></i>
                </a>
                <span class="text-muted">Back to Choices</span>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-plus-circle me-2"></i>Add New Choice Option</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <!-- معرف السؤال المرتبط به -->
                            <div class="col-md-6">
                                <label asp-for="QuestionId" class="form-label fw-semibold">Question ID</label>
                                <input asp-for="QuestionId" type="number" class="form-control" placeholder="Enter Question ID" />
                                <span asp-validation-for="QuestionId" class="text-danger small"></span>
                            </div>

                            <!-- تحديد هل الإجابة صحيحة أم لا -->
                            <div class="col-md-6 d-flex align-items-end mb-2">
                                <div class="form-check form-switch card p-2 px-4 w-100 border shadow-none bg-light mb-0">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" asp-for="IsCorrect" id="correctSwitch">
                                    <label class="form-check-label fw-semibold text-success" for="correctSwitch">
                                        <i class="bi bi-check-circle-fill me-1"></i> Is Correct Answer
                                    </label>
                                </div>
                            </div>

                            <!-- نص الاختيار -->
                            <div class="col-md-12">
                                <label asp-for="Content" class="form-label fw-semibold">Choice Content</label>
                                <textarea asp-for="Content" class="form-control" rows="3" placeholder="Type the answer option text here..."></textarea>
                                <span asp-validation-for="Content" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Save Choice</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

