@model EduSphere.Models.StudentAnswer

@{
    ViewData["Title"] = "Update Student Answer";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center gap-2 mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                    <i class="bi bi-arrow-left d-flex"></i>
                </a>
                <span class="text-muted">Back to List</span>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="card-title mb-0">Review & Update Student Answer</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="StudentAnswerId" />

                        <div class="row g-3">
                            <!-- رقم محاولة الامتحان -->
                            <div class="col-md-6">
                                <label asp-for="ExamAttemptId" class="form-label fw-semibold">Exam Attempt ID</label>
                                <input asp-for="ExamAttemptId" type="number" class="form-control" />
                                <span asp-validation-for="ExamAttemptId" class="text-danger small"></span>
                            </div>

                            <!-- رقم السؤال -->
                            <div class="col-md-6">
                                <label asp-for="QuestionId" class="form-label fw-semibold">Question ID</label>
                                <input asp-for="QuestionId" type="number" class="form-control" />
                                <span asp-validation-for="QuestionId" class="text-danger small"></span>
                            </div>

                            <!-- الاختيار المحدد -->
                            <div class="col-md-6">
                                <label asp-for="SelectedChoiceId" class="form-label fw-semibold">Selected Choice ID (Optional)</label>
                                <input asp-for="SelectedChoiceId" type="number" class="form-control" />
                                <span asp-validation-for="SelectedChoiceId" class="text-danger small"></span>
                            </div>

                            <!-- الدرجة المستحقة (مهمة جداً للمدرس أثناء التصحيح) -->
                            <div class="col-md-6">
                                <label asp-for="MarksAwarded" class="form-label fw-semibold text-success">Marks Awarded</label>
                                <input asp-for="MarksAwarded" type="number" step="0.5" class="form-control border-success fw-bold text-success" />
                                <span asp-validation-for="MarksAwarded" class="text-danger small"></span>
                            </div>

                            <!-- نص الإجابة المقالية -->
                            <div class="col-md-12">
                                <label asp-for="EssayAnswer" class="form-label fw-semibold">Essay Answer</label>
                                <textarea asp-for="EssayAnswer" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="EssayAnswer" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light">Cancel</a>
                            <button type="submit" class="btn btn-warning px-4">Update & Grade</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

