@model EduSphere.ViewModel.QuestionsVM

@{
    ViewData["Title"] = "Questions Management";
}

<div class="container-fluid py-4">
    @if (TempData["success-notification"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success-notification"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Questions</h1>
            <p class="text-muted small mb-0">Manage bank of questions, exam assignments, types, and marks allocation.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Add New Question
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group">
                        <input type="text" name="query" value="@ViewBag.Query" class="form-control" placeholder="Search by question content..." />
                        <button class="btn btn-secondary" type="submit">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(ViewBag.Query))
                {
                    <div class="col-auto">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear Filter</a>
                    </div>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Question Content</th>
                            <th>Exam</th>
                            <th>Type</th>
                            <th>Marks</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Questions != null && Model.Questions.Any())
                        {
                            @foreach (var item in Model.Questions)
                            {
                                <tr>
                                    <!-- المعرف ID في عمود منفصل ومتناسق -->
                                    <td class="text-muted ps-4" style="width: 80px;">
                                        #@item.QuestionId
                                    </td>
                                    <!-- محتوى السؤال -->
                                    <td class="fw-semibold text-dark text-wrap" style="max-width: 350px;">
                                        @item.Content
                                    </td>
                                    <!-- اسم الامتحان -->
                                    <td>@(item.Exam?.Title ?? "N/A")</td>
                                    <!-- نوع السؤال -->
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @item.Type
                                        </span>
                                    </td>
                                    <!-- درجات السؤال -->
                                    <td>
                                        <span class="fw-bold text-success">@item.Marks Pts</span>
                                    </td>
                                    <!-- العمليات والتوجيه -->
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Update" asp-route-id="@item.QuestionId" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.QuestionId" method="post" onsubmit="return confirm('Are you sure you want to delete this question?');" style="display:inline;">
                                                <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <!-- تعديل الـ colspan هنا ليغطي الـ 6 أعمدة بالكامل -->
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-question-circle display-4 d-block mb-3"></i>
                                    No questions found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="small text-muted">Page @Model.CurrentPage of @Model.TotalPages</span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = i, query = ViewBag.Query })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>