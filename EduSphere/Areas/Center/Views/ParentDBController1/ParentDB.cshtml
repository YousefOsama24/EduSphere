@model EduSphere.ViewModel.ParentDashboardVM

@{
    ViewData["Title"] = "Parent Dashboard";
}

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="fw-bold">
                Parent Dashboard
            </h2>
            <hr />
        </div>
    </div>

    <!-- ========================= -->
    <!-- Statistics -->
    <!-- ========================= -->

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body text-center">
                    <h6>Total Children</h6>
                    <h3 class="text-primary">
                        @Model.Children.Count()
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success shadow-sm">
                <div class="card-body text-center">
                    <h6>Attendance</h6>

                    <h3 class="text-success">
                        @Model.AttendancePercentage %
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-info shadow-sm">
                <div class="card-body text-center">

                    <h6>Present</h6>

                    <h3 class="text-info">
                        @Model.PresentCount
                    </h3>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger shadow-sm">
                <div class="card-body text-center">

                    <h6>Absent</h6>

                    <h3 class="text-danger">
                        @Model.AbsentCount
                    </h3>

                </div>
            </div>
        </div>

    </div>


    <!-- ========================= -->
    <!-- Parent Information -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-dark text-white">

            <h5 class="mb-0">
                Parent Information
            </h5>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="fw-bold">
                        Parent Name
                    </label>

                    <p>
                        @(Model.Parent.User?.FullName ?? "-")
                    </p>

                </div>

                <div class="col-md-6 mb-3">

                    <label class="fw-bold">
                        Occupation
                    </label>

                    <p>
                        @Model.Parent.Occupation
                    </p>

                </div>

                <div class="col-md-6 mb-3">

                    <label class="fw-bold">
                        Email
                    </label>

                    <p>
                        @(Model.Parent.User?.Email ?? "-")
                    </p>

                </div>

                <div class="col-md-6 mb-3">

                    <label class="fw-bold">
                        Phone
                    </label>

                    <p>
                        @(Model.Parent.User?.PhoneNumber ?? "-")
                    </p>

                </div>

            </div>

        </div>

    </div>
    <!-- ========================= -->
    <!-- Children -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                My Children
            </h5>

        </div>

        <div class="card-body">

            @if (Model.Children.Any())
            {
                <div class="table-responsive">

                    <table class="table table-bordered table-hover align-middle">

                        <thead class="table-light">

                            <tr>

                                <th>#</th>

                                <th>Name</th>

                                <th>Academic Level</th>

                                <th>Gender</th>

                                <th>Date Of Birth</th>

                                <th>Center</th>

                            </tr>

                        </thead>

                        <tbody>

                            @{
                                int index = 1;
                            }

                            @foreach (var child in Model.Children)
                            {
                                <tr>

                                    <td>@index</td>

                                    <td>
                                        @(child.User?.FullName ?? "-")
                                    </td>

                                    <td>
                                        @child.AcademicLevel
                                    </td>

                                    <td>
                                        @child.Gender
                                    </td>

                                    <td>
                                        @child.DateOfBirth.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        @(child.Center?.Name ?? "-")
                                    </td>

                                </tr>

                                index++;
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">

                    No children found.

                </div>
            }

        </div>

    </div>
    <!-- ========================= -->
    <!-- Attendance -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-success text-white">

            <h5 class="mb-0">

                Latest Attendance

            </h5>

        </div>

        <div class="card-body">

            @if (Model.AttendanceRecords.Any())
            {
                <div class="table-responsive">

                    <table class="table table-striped table-hover">

                        <thead>

                            <tr>

                                <th>Student</th>

                                <th>Date</th>

                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model.AttendanceRecords)
                            {
                                <tr>

                                    <td>
                                        @item.StudentName
                                    </td>

                                    <td>
                                        @item.Date.ToString("dd MMM yyyy")
                                    </td>

                                    <td>

                                        @if (item.IsPresent)
                                        {
                                            <span class="badge bg-success">

                                                Present

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">

                                                Absent

                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">

                    No attendance records available.

                </div>
            }

        </div>

    </div>
    <!-- ========================= -->
    <!-- Teachers -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-info text-white">

            <h5 class="mb-0">
                Teachers
            </h5>

        </div>

        <div class="card-body">

            @if (Model.Teachers.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover table-bordered">

                        <thead class="table-light">

                            <tr>

                                <th>Name</th>

                                <th>Specialization</th>

                                <th>Phone</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var teacher in Model.Teachers)
                            {
                                <tr>

                                    <td>@teacher.Name</td>

                                    <td>@teacher.Subject</td>

                                    <td>@teacher.Phone</td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-secondary mb-0">

                    No teachers found.

                </div>
            }

        </div>

    </div>


    <!-- ========================= -->
    <!-- Fees Summary -->
    <!-- ========================= -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card border-primary">

                <div class="card-body text-center">

                    <h6>Total Fees</h6>

                    <h3 class="text-primary">
                        @Model.TotalFees
                    </h3>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-success">

                <div class="card-body text-center">

                    <h6>Paid</h6>

                    <h3 class="text-success">
                        @Model.PaidFees
                    </h3>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-danger">

                <div class="card-body text-center">

                    <h6>Remaining</h6>

                    <h3 class="text-danger">
                        @Model.RemainingFees
                    </h3>

                </div>

            </div>

        </div>

    </div>


    <!-- ========================= -->
    <!-- Upcoming Exams -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header">

            <h5 class="mb-0">

                Upcoming Exams

            </h5>

        </div>

        <div class="card-body">

            @if (Model.UpcomingExams.Any())
            {
                <table class="table table-striped">

                    <thead>

                        <tr>

                            <th>Student</th>

                            <th>Subject</th>

                            <th>Date</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var exam in Model.UpcomingExams)
                        {
                            <tr>

                                <td>@exam.StudentName</td>

                                <td>@exam.Subject</td>

                                <td>@exam.Date.ToString("dd MMM yyyy")</td>

                            </tr>
                        }

                    </tbody>

                </table>
            }
            else
            {
                <div class="alert alert-light">

                    No upcoming exams.

                </div>
            }

        </div>

    </div>


    <!-- ========================= -->
    <!-- Assignments -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header">

            <h5 class="mb-0">

                Assignments

            </h5>

        </div>

        <div class="card-body">

            @if (Model.Assignments.Any())
            {
                <table class="table table-hover">

                    <thead>

                        <tr>

                            <th>Student</th>

                            <th>Assignment</th>

                            <th>Due Date</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.Assignments)
                        {
                            <tr>

                                <td>@item.StudentName</td>

                                <td>@item.Title</td>

                                <td>@item.DueDate.ToString("dd MMM yyyy")</td>

                                <td>

                                    @if (item.IsSubmitted)
                                    {
                                        <span class="badge bg-success">

                                            Submitted

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">

                                            Pending

                                        </span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }
            else
            {
                <div class="alert alert-light">

                    No assignments.

                </div>
            }

        </div>

    </div>

    <!-- ========================= -->
    <!-- Grades -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-warning">

            <h5 class="mb-0">

                Grades

            </h5>

        </div>

        <div class="card-body">

            @if (Model.Grades.Any())
            {
                <div class="table-responsive">

                    <table class="table table-bordered table-hover">

                        <thead class="table-light">

                            <tr>

                                <th>Student</th>

                                <th>Subject</th>

                                <th>Mark</th>

                                <th>Percentage</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var grade in Model.Grades)
                            {
                                <tr>

                                    <td>@grade.StudentName</td>

                                    <td>@grade.Subject</td>

                                    <td>@grade.Mark</td>

                                    <td>@grade.Percentage %</td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-light mb-0">

                    No grades available.

                </div>
            }

        </div>

    </div>



    <!-- ========================= -->
    <!-- Notifications -->
    <!-- ========================= -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-secondary text-white">

            <h5 class="mb-0">

                Notifications

            </h5>

        </div>

        <div class="card-body">

            @if (Model.Notifications.Any())
            {
                <ul class="list-group">

                    @foreach (var notification in Model.Notifications)
                    {
                        <li class="list-group-item">

                            <div class="d-flex justify-content-between">

                                <strong>

                                    @notification.Title

                                </strong>

                                <small>

                                    @notification.CreatedAt.ToString("dd MMM yyyy")

                                </small>

                            </div>

                            <div class="mt-2">

                                @notification.Message

                            </div>

                        </li>
                    }

                </ul>
            }
            else
            {
                <div class="alert alert-light mb-0">

                    No notifications.

                </div>
            }

        </div>

    </div>



    <!-- ========================= -->
    <!-- Dashboard Footer -->
    <!-- ========================= -->

    <div class="text-center text-muted mt-4 mb-3">

        <small>

            EduSphere Parent Dashboard

        </small>

    </div>

</div>