
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Teacher Dashboard · Brightleaf Learning Center</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
</head>
<body data-role="teacher">

    <div class="app-shell">

        <!-- Sidebar -->
        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-brand">
                <div class="mark">B</div>
                <div>
                    <div class="name">Brightleaf</div>
                    <div class="sub">Learning Center</div>
                </div>
            </div>
            <div class="sidebar-role-tab"><i class="bi bi-easel me-1"></i> Teacher portal</div>

            <nav class="sidebar-nav">
                <div class="nav-section">Main</div>

             
                <a class="nav-link" href="/Center/Student/Index"><i class="bi bi-calendar2-check"></i> Student</a>
                <a class="nav-link" href="/Center/Schedule/Index"><i class="bi bi-calendar2-check"></i> Schedule</a>
                <a class="nav-link" href="/Center/AttendanceSession/Index"><i class="bi bi-calendar2-check"></i> AttendanceSession</a>
                <a class="nav-link" href="/Center/AttendanceRecord/Index"><i class="bi bi-calendar2-check"></i> AttendanceRecord</a>
                <a class="nav-link" href="/Teacher/Course/Index"><i class="bi bi-calendar2-check"></i> Courses</a>
                <a class="nav-link" href="/Teacher/Group/Index"><i class="bi bi-calendar2-check"></i> Groups</a>
                <a class="nav-link" href="/Teacher/Exam/Index"><i class="bi bi-calendar2-check"></i> Exams</a>
                <a class="nav-link" href="/Teacher/Question/Index"><i class="bi bi-calendar2-check"></i> Question</a>
                <a class="nav-link" href="/Teacher/Choice/Index"><i class="bi bi-calendar2-check"></i> Choice</a>
                <a class="nav-link" href="/Teacher/StudentAnswer/Index"><i class="bi bi-calendar2-check"></i> StudentAnswer</a>
                <a class="nav-link" href="/Teacher/Lecture/Index"><i class="bi bi-calendar2-check"></i> Lectures</a>
                
              
       
                <div class="nav-section">Account</div>
                <a class="nav-link" href="#">
                    <i class="bi bi-chat-dots"></i> Messages
                    <span class="badge rounded-pill ms-auto" style="background:var(--pen-red); font-size:.65rem;">5</span>
                </a>
                <a class="nav-link" href="#"><i class="bi bi-gear"></i> Settings</a>
                <a class="nav-link" href="index.html"><i class="bi bi-box-arrow-left"></i> Sign out</a>
            </nav>

            <div class="sidebar-foot">
                <div class="id-badge">LF</div>
                <div class="who">
                    Mrs. Ferrara<br>
                    <small>Science Department</small>
                </div>
            </div>
        </aside>
        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- Main -->
        <div class="main">
            <header class="topbar">
                <button class="btn-icon sidebar-toggle" data-toggle="sidebar" aria-label="Open menu"><i class="bi bi-list fs-5"></i></button>
                <div>
                    <div class="page-kicker">Teacher portal</div>
                    <h1 class="page-title">Welcome back, Mrs. Ferrara</h1>
                </div>
                <div class="spacer"></div>
                <button class="btn btn-role d-none d-md-inline-flex align-items-center gap-2"><i class="bi bi-plus-lg"></i> New assignment</button>
                <button class="btn-icon" aria-label="Notifications"><i class="bi bi-bell"></i><span class="dot"></span></button>
                <div class="id-photo sm">LF</div>
            </header>

            <div class="content">

                <!-- KPI row -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-lg-3">
                        <div class="stat-card">
                            <div class="label">Classes taught</div>
                            <div class="value">4</div>
                            <div class="foot">128 students total</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-card" style="--accent:var(--pen-red);">
                            <div class="label">To grade</div>
                            <div class="value">12</div>
                            <div class="foot">oldest submitted 3 days ago</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-card" style="--accent:var(--gold);">
                            <div class="label">Exams this month</div>
                            <div class="value">2</div>
                            <div class="foot">next: Chemistry, Jul 06</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-card" style="--accent:var(--chalk-green);">
                            <div class="label">Class average</div>
                            <div class="value">83<span style="font-size:1rem; color:var(--graphite-soft);">%</span></div>
                            <div class="foot up"><i class="bi bi-arrow-up-short"></i> up 1.4 pts</div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <!-- Grading queue -->
                    <div class="col-lg-7" id="grading">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Grading queue</h2>
                                <span class="spacer"></span>
                                <a href="#" class="small">Open gradebook</a>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-ledger">
                                    <thead><tr><th>Student</th><th>Assignment</th><th>Class</th><th>Submitted</th><th></th></tr></thead>
                                    <tbody>
                                        <tr>
                                            <td class="d-flex align-items-center gap-2"><div class="id-photo sm">AM</div> Amara Michaels</td>
                                            <td>Lab report — Titration curves</td>
                                            <td class="text-muted">Chem 10B</td>
                                            <td class="data">Jun 30</td>
                                            <td class="text-end"><button class="btn btn-sm btn-outline-ink">Grade</button></td>
                                        </tr>
                                        <tr>
                                            <td class="d-flex align-items-center gap-2"><div class="id-photo sm">DK</div> Devon Kalu</td>
                                            <td>Lab report — Titration curves</td>
                                            <td class="text-muted">Chem 10B</td>
                                            <td class="data">Jun 30</td>
                                            <td class="text-end"><button class="btn btn-sm btn-outline-ink">Grade</button></td>
                                        </tr>
                                        <tr>
                                            <td class="d-flex align-items-center gap-2"><div class="id-photo sm">RS</div> Rhea Singh</td>
                                            <td>Periodic trends worksheet</td>
                                            <td class="text-muted">Chem 10A</td>
                                            <td class="data">Jul 01</td>
                                            <td class="text-end"><button class="btn btn-sm btn-outline-ink">Grade</button></td>
                                        </tr>
                                        <tr>
                                            <td class="d-flex align-items-center gap-2"><div class="id-photo sm">JT</div> Jonah Tran</td>
                                            <td>Periodic trends worksheet</td>
                                            <td class="text-muted">Chem 10A</td>
                                            <td class="data">Jul 01</td>
                                            <td class="text-end"><button class="btn btn-sm btn-outline-ink">Grade</button></td>
                                        </tr>
                                        <tr>
                                            <td class="d-flex align-items-center gap-2"><div class="id-photo sm">NE</div> Nia Edwards</td>
                                            <td>Lab safety quiz</td>
                                            <td class="text-muted">Chem 9C</td>
                                            <td class="data">Jul 02</td>
                                            <td class="text-end"><button class="btn btn-sm btn-outline-ink">Grade</button></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- My classes -->
                    <div class="col-lg-5" id="classes">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>My classes</h2>
                            </div>
                            <div class="paper-body pt-2">
                                <div class="due-row">
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Chemistry 10A</div>
                                        <div class="small text-muted">32 students · Period 1</div>
                                    </div>
                                    <span class="score-mark good">85</span>
                                </div>
                                <div class="due-row">
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Chemistry 10B</div>
                                        <div class="small text-muted">30 students · Period 3</div>
                                    </div>
                                    <span class="score-mark mid">78</span>
                                </div>
                                <div class="due-row">
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Chemistry 9C</div>
                                        <div class="small text-muted">34 students · Period 5</div>
                                    </div>
                                    <span class="score-mark good">88</span>
                                </div>
                                <div class="due-row">
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">AP Chemistry</div>
                                        <div class="small text-muted">22 students · Period 6</div>
                                    </div>
                                    <span class="score-mark good">91</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <!-- Exams management -->
                    <div class="col-lg-7" id="exams">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Exams</h2>
                                <span class="spacer"></span>
                                <button class="btn btn-sm btn-role"><i class="bi bi-plus-lg"></i> Schedule exam</button>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-ledger">
                                    <thead><tr><th>Exam</th><th>Class</th><th>Date</th><th>Status</th><th></th></tr></thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Midterm</strong></td>
                                            <td class="text-muted">Chem 10B</td>
                                            <td class="data">Jul 06</td>
                                            <td><span class="pill pill-due">Scheduled</span></td>
                                            <td class="text-end"><a href="#" class="small">Edit</a></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Unit 4 quiz</strong></td>
                                            <td class="text-muted">Chem 10A</td>
                                            <td class="data">Jul 03</td>
                                            <td><span class="pill pill-good">Graded</span></td>
                                            <td class="text-end"><a href="#" class="small">View results</a></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Lab practical</strong></td>
                                            <td class="text-muted">AP Chemistry</td>
                                            <td class="data">Jun 27</td>
                                            <td><span class="pill pill-good">Graded</span></td>
                                            <td class="text-end"><a href="#" class="small">View results</a></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Final exam</strong></td>
                                            <td class="text-muted">Chem 9C</td>
                                            <td class="data">Jul 21</td>
                                            <td><span class="pill pill-info">Draft</span></td>
                                            <td class="text-end"><a href="#" class="small">Edit</a></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Attendance quick take -->
                    <div class="col-lg-5" id="attendance">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Take attendance</h2>
                                <span class="spacer"></span>
                                <span class="hint mono">Chem 10A · Per. 1</span>
                            </div>
                            <div class="paper-body pt-2">
                                <div class="due-row">
                                    <div class="id-photo sm me-0">AM</div>
                                    <div class="flex-grow-1 ms-2">Amara Michaels</div>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-ink active">P</button>
                                        <button class="btn btn-outline-ink">L</button>
                                        <button class="btn btn-outline-ink">A</button>
                                    </div>
                                </div>
                                <div class="due-row">
                                    <div class="id-photo sm me-0">DK</div>
                                    <div class="flex-grow-1 ms-2">Devon Kalu</div>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-ink active">P</button>
                                        <button class="btn btn-outline-ink">L</button>
                                        <button class="btn btn-outline-ink">A</button>
                                    </div>
                                </div>
                                <div class="due-row">
                                    <div class="id-photo sm me-0">RS</div>
                                    <div class="flex-grow-1 ms-2">Rhea Singh</div>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-ink">P</button>
                                        <button class="btn btn-outline-ink active">L</button>
                                        <button class="btn btn-outline-ink">A</button>
                                    </div>
                                </div>
                                <div class="due-row">
                                    <div class="id-photo sm me-0">JT</div>
                                    <div class="flex-grow-1 ms-2">Jonah Tran</div>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-ink">P</button>
                                        <button class="btn btn-outline-ink">L</button>
                                        <button class="btn btn-outline-ink active">A</button>
                                    </div>
                                </div>
                                <button class="btn btn-ink w-100 mt-2">Save attendance</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Performance chart + messages -->
                <div class="row g-3">
                    <div class="col-lg-7">
                        <div class="paper h-100">
                            <div class="ledger-head"><span class="tab"></span><h2>Class performance — last 6 assessments</h2></div>
                            <div class="paper-body">
                                <canvas id="perfChart" height="130"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div class="paper h-100">
                            <div class="ledger-head"><span class="tab"></span><h2>Recent messages</h2></div>
                            <div class="paper-body pt-2">
                                <div class="mb-3 pb-3" style="border-bottom:1px dashed var(--rule);">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold small" style="color:var(--ink);">Parent of Amara Michaels</span>
                                        <span class="small text-muted mono">10:12</span>
                                    </div>
                                    <p class="small text-muted mb-0">Could we set up a short call about the lab report grade?</p>
                                </div>
                                <div class="mb-3 pb-3" style="border-bottom:1px dashed var(--rule);">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold small" style="color:var(--ink);">Dept. Head — Ortiz</span>
                                        <span class="small text-muted mono">Yesterday</span>
                                    </div>
                                    <p class="small text-muted mb-0">Reminder: submit midterm question banks by Friday.</p>
                                </div>
                                <div>
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold small" style="color:var(--ink);">Rhea Singh</span>
                                        <span class="small text-muted mono">Mon</span>
                                    </div>
                                    <p class="small text-muted mb-0">I'll be out Thursday for a family event — makeup work?</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/script.js"></script>
    <script>
        new Chart(document.getElementById('perfChart'), {
          type: 'bar',
          data: {
            labels: ['Quiz 1','Quiz 2','Lab 1','Quiz 3','Midterm mock','Lab 2'],
            datasets: [{
              label: 'Class average %',
              data: [79, 82, 75, 84, 80, 86],
              backgroundColor: '#2F5D3A',
              borderRadius: 4,
              maxBarThickness: 34
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, max: 100, grid: { color: '#EAE3D0' } },
              x: { grid: { display: false } }
            }
          }
        });
    </script>
</body>
</html>
