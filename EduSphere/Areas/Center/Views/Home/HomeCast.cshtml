@{
    ViewData["Title"] = "Courses";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - EduSphere</title>

    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
</head>

<body class="courses-page">

    <!-- =========================
         Top Navigation
    ========================== -->
    <header class="registry-topbar">

        <a class="brand" href="/">
            <span class="mark">ES</span>
            <span>EduSphere</span>
        </a>

        <nav class="main-nav">
            <a href="/">Home</a>
            <a href="#courses">Courses</a>
            <a href="#instructors">Instructors</a>
            <a href="#about">About Us</a>
        </nav>

        <a class="cta-btn"
               asp-area="Identity"
               asp-controller="Account"
               asp-action="Register">
            Get Started
        </a>

    </header>


    <!-- =========================
         Hero Section
    ========================== -->
    <section class="registry-hero">

        <div class="hero-inner">

            <div class="hero-content">

                <div class="eyebrow">
                    EDUSPHERE COURSE CATALOG — 2026
                </div>

                <h1>
                    Discover courses taught by experienced instructors
                </h1>

                <p class="lede">
                    Explore educational courses designed to help students
                    develop their skills and achieve their learning goals.
                </p>


                <!-- Statistics -->
                <div class="ledger-strip">

                    <div class="entry">
                        <span class="num">0</span>
                        <span class="label">Available Courses</span>
                    </div>

                    <div class="entry">
                        <span class="num">0</span>
                        <span class="label">Instructors</span>
                    </div>

                    <div class="entry">
                        <span class="num">4.8</span>
                        <span class="label">Average Rating</span>
                    </div>

                </div>

            </div>


            <!-- =========================
                 Filters
            ========================== -->
            <aside class="filter-panel">

                <h3>Find Your Course</h3>

                <div class="field">
                    <label for="course-search">
                        Course or Instructor
                    </label>

                    <input type="text"
                           id="course-search"
                           placeholder="Example: Mathematics" />
                </div>


                <div class="field">

                    <label for="course-category">
                        Category
                    </label>

                    <select id="course-category">

                        <option value="all">
                            All Categories
                        </option>

                        <option value="business">
                            Business
                        </option>

                        <option value="design">
                            Design
                        </option>

                        <option value="tech">
                            Technology & Programming
                        </option>

                    </select>

                </div>


                <div class="field">

                    <label for="course-level">
                        Level
                    </label>

                    <select id="course-level">

                        <option value="all">
                            All Levels
                        </option>

                        <option value="beginner">
                            Beginner
                        </option>

                        <option value="intermediate">
                            Intermediate
                        </option>

                        <option value="advanced">
                            Advanced
                        </option>

                    </select>

                </div>


                <button type="button"
                        id="apply-filters"
                        class="apply-btn">

                    Apply Filters

                </button>

            </aside>

        </div>

    </section>


    <!-- =========================
         Course Archive
    ========================== -->
    <main class="course-archive"
          id="courses">

        <div class="archive-heading">

            <div>
                <span class="section-label">
                    EXPLORE
                </span>

                <h2>
                    Available Courses
                </h2>
            </div>

            <span class="count-tag"
                  id="result-count">

                0 Courses Found

            </span>

        </div>


        <!-- Course Grid -->
        <div class="course-grid"
             id="course-grid">

            <!--
                Course cards will be rendered here
                when course data is connected to the backend.
            -->

        </div>


        <!-- Empty State -->
        <div class="archive-empty"
             id="archive-empty">

            <h4>
                No Courses Found
            </h4>

            <p>
                Try changing your search term
                or removing one of the filters.
            </p>

        </div>

    </main>


    <!-- =========================
         Footer
    ========================== -->
    <footer class="registry-footer">

        <p>
            © @DateTime.Now.Year EduSphere.
            All rights reserved.
        </p>

    </footer>


    <script src="~/js/courses.js"
            asp-append-version="true">
    </script>

</body>
</html>