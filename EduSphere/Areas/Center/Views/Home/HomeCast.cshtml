
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]EduSphere </title>
    <link rel="stylesheet" href="~/css/courses.css" />

</head>
<body class="courses-page">

    <!-- ===== Top bar ===== -->
    <header class="registry-topbar">
        <div class="brand">
            <span class="mark">AK</span>
            أكاديمية المعرفة
        </div>
        <nav>
            <a href="#">الرئيسية</a>
            <a href="#">الدورات</a>
            <a href="#">المدرسون</a>
            <a href="#">من نحن</a>
        </nav>
        <a class="cta-btn" href="@Url.Action("Register", "Account")">سجّل الآن</a>
    </header>

    <!-- ===== Hero + ledger strip ===== -->
    <section class="registry-hero">
        <div class="hero-inner">
            <div>
                <div class="eyebrow">سجل الاعتماد التدريبي — 2026</div>
                <h1>دورات موثّقة، يقدّمها مدرّبون معتمدون في مجالاتهم</h1>
                <p class="lede">كل دورة في هذا السجل مراجعة ومعتمدة من فريق الأكاديمية، ومقدَّمة من مدرّس متخصص له سجل حافل في مجاله.</p>

                <div class="ledger-strip">
                    <div class="entry">
                        <span class="num"></span>
                        <span class="label">دورة متاحة</span>
                    </div>
                    <div class="entry">
                        <span class="num"></span>
                        <span class="label">مدرّس معتمد</span>
                    </div>
                    <div class="entry">
                        <span class="num">4.8</span>
                        <span class="label">متوسط تقييم الدارسين</span>
                    </div>
                </div>
            </div>

            <aside class="filter-panel">
                <h3>ابحث في السجل</h3>
                <div class="field">
                    <label for="course-search">اسم الدورة أو المدرّس</label>
                    <input type="text" id="course-search" placeholder="مثال: تسويق رقمي" />
                </div>
                <div class="field">
                    <label for="course-category">التخصص</label>
                    <select id="course-category">
                        <option value="all">كل التخصصات</option>
                        <option value="business">إدارة وأعمال</option>
                        <option value="design">تصميم</option>
                        <option value="tech">تقنية وبرمجة</option>
                    </select>
                </div>
                <div class="field">
                    <label for="course-level">المستوى</label>
                    <select id="course-level">
                        <option value="all">كل المستويات</option>
                        <option value="beginner">مبتدئ</option>
                        <option value="intermediate">متوسط</option>
                        <option value="advanced">متقدم</option>
                    </select>
                </div>
                <button type="button" id="apply-filters" class="apply-btn">تطبيق الفلترة</button>
            </aside>
        </div>
    </section>

    <!-- ===== Course archive ===== -->
    <main class="course-archive">
        <div class="archive-heading">
            <h2>الدورات المتاحة</h2>
            <span class="count-tag" id="result-count"> دورة مطابقة</span>
        </div>

        <div class="course-grid" id="course-grid">
            @* @if (Model != null)
            {
                @foreach (var course in Model)
                { *@
                    <div class="course-card cat-.CategorySlug"
                         data-title=""
                         data-instructor=""
                         data-category=""
                         data-level="">
                        <span class="tab"></span>

                        <div class="instructor-row">
                            <div class="avatar">
                                
                            </div>
                            <div>
                                <div class="instructor-name"></div>
                                <div class="instructor-title"></div>
                            </div>
                        </div>

                        <h3 class="course-title"></h3>
                        <p class="course-desc"></p>

                        <div class="stat-row">
                            <span><strong></strong> ساعة</span>
                            <span><strong>t</strong> دارس</span>
                            <span><strong>course.LevelLabel</strong></span>
                        </div>

                        @* <a class="enroll-link" href="" </a> *@
                    </div>
                }
            }
        </div>

        <div class="archive-empty" id="archive-empty">
            <h4>لا توجد دورات مطابقة</h4>
            <p>جرّب تعديل كلمة البحث أو إزالة أحد الفلاتر.</p>
        </div>
    </main>

    <footer class="registry-footer">
        أكاديمية المعرفة — جميع الحقوق محفوظة
    </footer>

    <script src="~/js/courses.js"></script>
</body>
</html>



<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Cairo", sans-serif;
    }

    body {
        background: #f5f7fb;
        color: #333;
    }

    /* Top Bar */
    .registry-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 40px;
        background: #0d6efd;
        color: white;
    }

        .registry-topbar nav a {
            color: white;
            text-decoration: none;
            margin: 0 10px;
            transition: .3s;
        }

            .registry-topbar nav a:hover {
                color: #ffd54f;
            }

    .brand {
        font-size: 22px;
        font-weight: bold;
    }

    .mark {
        background: white;
        color: #0d6efd;
        padding: 4px 8px;
        border-radius: 6px;
        margin-left: 5px;
    }

    .cta-btn {
        background: white;
        color: #0d6efd;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

    /* Hero */
    .registry-hero {
        padding: 50px;
        background: linear-gradient(135deg,#0d6efd,#4f8ef7);
        color: white;
    }

    .hero-inner {
        display: flex;
        justify-content: space-between;
        gap: 30px;
        flex-wrap: wrap;
    }

        .hero-inner h1 {
            margin: 15px 0;
            font-size: 36px;
        }

    .lede {
        line-height: 1.8;
        max-width: 700px;
    }

    .ledger-strip {
        display: flex;
        gap: 15px;
        margin-top: 25px;
    }

    .entry {
        background: rgba(255,255,255,.15);
        padding: 15px;
        border-radius: 10px;
        text-align: center;
        min-width: 120px;
    }

    /* Filter */
    .filter-panel {
        background: white;
        color: black;
        padding: 20px;
        border-radius: 12px;
        width: 300px;
        box-shadow: 0 5px 20px rgba(0,0,0,.1);
    }

    .field {
        margin-bottom: 15px;
    }

        .field label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .field input,
        .field select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

    .apply-btn {
        width: 100%;
        padding: 10px;
        border: none;
        background: #0d6efd;
        color: white;
        border-radius: 8px;
        cursor: pointer;
    }

    /* Archive */
    .course-archive {
        padding: 40px;
    }

    .archive-heading {
        display: flex;
        justify-content: space-between;
        margin-bottom: 25px;
    }

    .count-tag {
        background: #0d6efd;
        color: white;
        padding: 8px 15px;
        border-radius: 20px;
    }

    .course-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(300px,1fr));
        gap: 25px;
    }

    .course-card {
        background: white;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,.08);
        transition: .3s;
    }

        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
        }

    .course-title {
        margin: 15px 0;
        color: #0d6efd;
    }

    .course-desc {
        color: #666;
        margin-bottom: 15px;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 14px;
    }

    .enroll-link {
        display: block;
        text-align: center;
        background: #0d6efd;
        color: white;
        text-decoration: none;
        padding: 10px;
        border-radius: 8px;
    }

    .archive-empty {
        text-align: center;
        margin-top: 40px;
        color: #777;
    }

    .registry-footer {
        text-align: center;
        padding: 20px;
        background: #0d6efd;
        color: white;
        margin-top: 50px;
    }

    @@media (max-width:768px) {

        .registry-topbar,
        .hero-inner {
            flex-direction: column;
            text-align: center;
        }

        .filter-panel {
            width: 100%;
        }

        .ledger-strip {
            justify-content: center;
            flex-wrap: wrap;
        }
    }
</style>