@model EduSphere.ViewModel.ParentDashboardVM
@{
    ViewData["Title"] = "لوحة ولي الأمر";
}

<div class="container mt-4" dir="rtl">
    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body d-flex align-items-center">
            <div class="bg-primary text-white rounded-circle p-3 me-3">
                <i class="bi bi-person-bounding-box fs-2"></i>
            </div>
            <div>
                <h4 class="mb-1 fw-bold">مرحباً بك، @(Model.Parent?.User?.FullName ?? "ولي الأمر")</h4>
                <p class="text-muted mb-0">تابع أداء ومستحقات أطفالك الدراسية من مكان واحد.</p>
            </div>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-4 border-success">
                <h6 class="text-muted">نسبة الحضور الإجمالية</h6>
                <h2 class="fw-bold text-success mb-0">@Model.AttendancePercentage%</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-4 border-info">
                <h6 class="text-muted">متوسط الدرجات</h6>
                <h2 class="fw-bold text-info mb-0">@Model.AverageGrade</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-4 border-warning">
                <h6 class="text-muted">إجمالي الرسوم المدفوعة</h6>
                <h2 class="fw-bold text-warning mb-0">@Model.PaidFees EGP</h2>
            </div>
        </div>
    </div>

    <!-- Children & Attendance Details -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-people text-primary me-2"></i>الأبناء المسجلين</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        @if (Model.Children != null && Model.Children.Any())
                        {
                            @foreach (var child in Model.Children)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span class="fw-semibold">@(child.User?.FullName ?? "طالب")</span>
                                    <span class="badge bg-secondary">كود: @child.StudentId</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted">لا يوجد أبناء مسجلين.</li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-calendar-check text-success me-2"></i>سجل الحضور والغياب الأخيرة</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>اسم الطالب</th>
                                <th>التاريخ</th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.AttendanceRecords != null && Model.AttendanceRecords.Any())
                            {
                                @foreach (var rec in Model.AttendanceRecords)
                                {
                                    <tr>
                                        <td>@rec.StudentName</td>
                                        <td>@rec.Date.ToString("yyyy/MM/dd")</td>
                                        <td>
                                            @if (rec.IsPresent)
                                            {
                                                <span class="badge bg-success">حاضر</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">غائب</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center text-muted">لا توجد سجلات حضور حتى الآن</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>