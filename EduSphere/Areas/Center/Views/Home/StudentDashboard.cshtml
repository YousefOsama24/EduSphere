<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Student Dashboard · Brightleaf Learning Center</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
</head>
<body data-role="student">

    <div class="app-shell">

        <!-- Sidebar -->
        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-brand">
                <div class="mark">B</div>
                <div>
                    <div class="name">Brightleaf</div>
                    <div class="sub">Learning Center</div>
                </div>
            </div>
            <div class="sidebar-role-tab"><i class="bi bi-mortarboard me-1"></i> Student portal</div>

            <nav class="sidebar-nav">
                <div class="nav-section">Main</div>
                <a class="nav-link active" href="student.html"><i class="bi bi-grid-1x2"></i> Overview</a>
                <a class="nav-link" href="#exams"><i class="bi bi-journal-text"></i> My exams</a>
                <a class="nav-link" href="#assignments"><i class="bi bi-clipboard-check"></i> Assignments</a>
                <a class="nav-link" href="#grades"><i class="bi bi-bar-chart-steps"></i> Grades &amp; report card</a>
                <a class="nav-link" href="#attendance"><i class="bi bi-calendar2-week"></i> Attendance</a>

                <div class="nav-section">Class</div>
                <a class="nav-link" href="#timetable"><i class="bi bi-clock-history"></i> Timetable</a>
                <a class="nav-link" href="#"><i class="bi bi-people"></i> My classmates</a>
                <a class="nav-link" href="#"><i class="bi bi-folder2-open"></i> Course materials</a>

                <div class="nav-section">Account</div>
                <a class="nav-link" href="#">
                    <i class="bi bi-chat-dots"></i> Messages
                    <span class="badge rounded-pill ms-auto" style="background:var(--pen-red); font-size:.65rem;">3</span>
                </a>
                <a class="nav-link" href="#"><i class="bi bi-gear"></i> Settings</a>
                <a class="nav-link" href="index.html"><i class="bi bi-box-arrow-left"></i> Sign out</a>
            </nav>

            <div class="sidebar-foot">
                <div class="id-badge">AM</div>
                <div class="who">
                    Amara Michaels<br>
                    <small>Grade 10 · Section B</small>
                </div>
            </div>
        </aside>
        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- Main -->
        <div class="main">
            <header class="topbar">
                <button class="btn-icon sidebar-toggle" data-toggle="sidebar" aria-label="Open menu"><i class="bi bi-list fs-5"></i></button>
                <div>
                    <div class="page-kicker">Student portal</div>
                    <h1 class="page-title">Good morning, Amara</h1>
                </div>
                <div class="spacer"></div>
                <div class="d-none d-md-flex align-items-center" style="width:260px;">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-color:var(--rule);"><i class="bi bi-search text-muted"></i></span>
                        <input type="search" class="form-control border-start-0" placeholder="Search classes, exams…" style="border-color:var(--rule);">
                    </div>
                </div>
                <button class="btn-icon" aria-label="Notifications"><i class="bi bi-bell"></i><span class="dot"></span></button>
                <div class="id-photo sm">AM</div>
            </header>

            <div class="content">

                <!-- KPI row -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-lg-3">
                        <div class="stat-card">
                            <div class="label">Overall average</div>
                            <div class="value">87.4<span style="font-size:1rem; color:var(--graphite-soft);">%</span></div>
                            <div class="foot up"><i class="bi bi-arrow-up-short"></i> 2.1 pts since last term</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-card" style="--accent:var(--pen-red);">
                            <div class="label">Assignments due</div>
                            <div class="value">4</div>
                            <div class="foot">next due in 2 days</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-card" style="--accent:var(--gold);">
                            <div class="label">Upcoming exams</div>
                            <div class="value">3</div>
                            <div class="foot">Chemistry starts Mon</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-card" style="--accent:var(--chalk-green);">
                            <div class="label">Attendance</div>
                            <div class="value">96<span style="font-size:1rem; color:var(--graphite-soft);">%</span></div>
                            <div class="foot">3 absences this term</div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <!-- Upcoming exams -->
                    <div class="col-lg-7" id="exams">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Upcoming exams</h2>
                                <span class="spacer"></span>
                                <a href="#" class="small">View exam schedule</a>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-ledger">
                                    <thead>
                                        <tr><th>Subject</th><th>Date</th><th>Room</th><th>Weight</th><th>Status</th></tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Chemistry</strong> — Midterm</td>
                                            <td class="data">Jul 06, 9:00 AM</td>
                                            <td class="data">Lab 2</td>
                                            <td class="data">25%</td>
                                            <td><span class="pill pill-due">Study now</span></td>
                                        </tr>
                                        <tr>
                                            <td><strong>World History</strong> — Unit test</td>
                                            <td class="data">Jul 09, 11:00 AM</td>
                                            <td class="data">Rm 114</td>
                                            <td class="data">15%</td>
                                            <td><span class="pill pill-warn">This week</span></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Algebra II</strong> — Final</td>
                                            <td class="data">Jul 21, 9:00 AM</td>
                                            <td class="data">Rm 208</td>
                                            <td class="data">40%</td>
                                            <td><span class="pill pill-info">Scheduled</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Assignments due -->
                    <div class="col-lg-5" id="assignments">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Assignments due</h2>
                                <span class="spacer"></span>
                                <a href="#" class="small">All</a>
                            </div>
                            <div class="paper-body pt-2">
                                <div class="due-row">
                                    <div class="due-date"><div class="d">05</div><div class="m">Jul</div></div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Lab report — Titration curves</div>
                                        <div class="small text-muted">Chemistry · Mrs. Ferrara</div>
                                    </div>
                                    <span class="pill pill-due">Due soon</span>
                                </div>
                                <div class="due-row">
                                    <div class="due-date"><div class="d">08</div><div class="m">Jul</div></div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Essay — Causes of the war</div>
                                        <div class="small text-muted">World History · Mr. Odell</div>
                                    </div>
                                    <span class="pill pill-warn">Drafting</span>
                                </div>
                                <div class="due-row">
                                    <div class="due-date"><div class="d">12</div><div class="m">Jul</div></div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Problem set 7</div>
                                        <div class="small text-muted">Algebra II · Ms. Okafor</div>
                                    </div>
                                    <span class="pill pill-info">Not started</span>
                                </div>
                                <div class="due-row">
                                    <div class="due-date"><div class="d">14</div><div class="m">Jul</div></div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Reading response 4</div>
                                        <div class="small text-muted">English · Mr. Bates</div>
                                    </div>
                                    <span class="pill pill-good">Submitted</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <!-- Grades -->
                    <div class="col-lg-7" id="grades">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Grades by subject</h2>
                                <span class="spacer"></span>
                                <span class="hint">Term 3 — in progress</span>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-ledger align-middle">
                                    <thead><tr><th>Subject</th><th>Teacher</th><th>Trend</th><th class="text-end">Grade</th></tr></thead>
                                    <tbody>
                                        <tr>
                                            <td>Chemistry</td>
                                            <td class="text-muted">Mrs. Ferrara</td>
                                            <td><div class="ledger-progress" style="width:110px;"><span style="width:82%;"></span></div></td>
                                            <td class="text-end"><span class="score-mark good">A-</span></td>
                                        </tr>
                                        <tr>
                                            <td>Algebra II</td>
                                            <td class="text-muted">Ms. Okafor</td>
                                            <td><div class="ledger-progress" style="width:110px;"><span style="width:74%;"></span></div></td>
                                            <td class="text-end"><span class="score-mark mid">B</span></td>
                                        </tr>
                                        <tr>
                                            <td>World History</td>
                                            <td class="text-muted">Mr. Odell</td>
                                            <td><div class="ledger-progress" style="width:110px;"><span style="width:90%;"></span></div></td>
                                            <td class="text-end"><span class="score-mark good">A</span></td>
                                        </tr>
                                        <tr>
                                            <td>English Literature</td>
                                            <td class="text-muted">Mr. Bates</td>
                                            <td><div class="ledger-progress" style="width:110px;"><span style="width:68%;"></span></div></td>
                                            <td class="text-end"><span class="score-mark mid">B-</span></td>
                                        </tr>
                                        <tr>
                                            <td>Physical Education</td>
                                            <td class="text-muted">Coach Reyes</td>
                                            <td><div class="ledger-progress" style="width:110px;"><span style="width:95%;"></span></div></td>
                                            <td class="text-end"><span class="score-mark good">A</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Attendance -->
                    <div class="col-lg-5" id="attendance">
                        <div class="paper h-100">
                            <div class="ledger-head">
                                <span class="tab"></span>
                                <h2>Attendance — this term</h2>
                            </div>
                            <div class="paper-body">
                                <canvas id="attendanceChart" height="170"></canvas>
                                <div class="d-flex justify-content-between mt-3 small">
                                    <div><span class="pill pill-good">Present 58</span></div>
                                    <div><span class="pill pill-warn">Late 2</span></div>
                                    <div><span class="pill pill-due">Absent 3</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Timetable + announcements -->
                <div class="row g-3">
                    <div class="col-lg-7" id="timetable">
                        <div class="paper h-100">
                            <div class="ledger-head"><span class="tab"></span><h2>Today's timetable</h2></div>
                            <div class="paper-body pt-2">
                                <div class="due-row">
                                    <div class="due-date"><div class="d mono" style="font-size:.85rem;">8:00</div><div class="m">AM</div></div>
                                    <div class="flex-grow-1"><div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Chemistry</div><div class="small text-muted">Lab 2 · Mrs. Ferrara</div></div>
                                    <span class="pill pill-good">Now</span>
                                </div>
                                <div class="due-row">
                                    <div class="due-date"><div class="d mono" style="font-size:.85rem;">9:15</div><div class="m">AM</div></div>
                                    <div class="flex-grow-1"><div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">Algebra II</div><div class="small text-muted">Rm 208 · Ms. Okafor</div></div>
                                    <span class="pill pill-muted">Next</span>
                                </div>
                                <div class="due-row">
                                    <div class="due-date"><div class="d mono" style="font-size:.85rem;">11:00</div><div class="m">AM</div></div>
                                    <div class="flex-grow-1"><div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">World History</div><div class="small text-muted">Rm 114 · Mr. Odell</div></div>
                                    <span class="pill pill-muted">Later</span>
                                </div>
                                <div class="due-row">
                                    <div class="due-date"><div class="d mono" style="font-size:.85rem;">1:30</div><div class="m">PM</div></div>
                                    <div class="flex-grow-1"><div class="fw-semibold" style="color:var(--ink); font-size:.9rem;">English Literature</div><div class="small text-muted">Rm 220 · Mr. Bates</div></div>
                                    <span class="pill pill-muted">Later</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="paper h-100">
                            <div class="ledger-head"><span class="tab"></span><h2>Announcements</h2></div>
                            <div class="paper-body pt-2">
                                <div class="mb-3 pb-3" style="border-bottom:1px dashed var(--rule);">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold small" style="color:var(--ink);">Report cards released</span>
                                        <span class="small text-muted mono">Jul 02</span>
                                    </div>
                                    <p class="small text-muted mb-0">Term 2 report cards are now visible under Grades &amp; report card.</p>
                                </div>
                                <div class="mb-3 pb-3" style="border-bottom:1px dashed var(--rule);">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold small" style="color:var(--ink);">Chemistry lab moved</span>
                                        <span class="small text-muted mono">Jun 29</span>
                                    </div>
                                    <p class="small text-muted mb-0">Friday's lab session moves to Lab 3 for equipment maintenance.</p>
                                </div>
                                <div>
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold small" style="color:var(--ink);">Library extended hours</span>
                                        <span class="small text-muted mono">Jun 25</span>
                                    </div>
                                    <p class="small text-muted mb-0">Open until 7 PM during exam weeks starting next Monday.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/script.js"></script>
    <script>
        const ctx = document.getElementById('attendanceChart');
        new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: ['Present', 'Late', 'Absent'],
            datasets: [{
              data: [58, 2, 3],
              backgroundColor: ['#2F5D3A', '#B8860B', '#B7472A'],
              borderColor: '#FFFEFB',
              borderWidth: 3
            }]
          },
          options: {
            cutout: '68%',
            plugins: { legend: { display: false } }
          }
        });
    </script>
</body>
</html>
