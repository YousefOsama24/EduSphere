@model EduSphere.ViewModel.StudentDashboardVM
@{
    ViewData["Title"] = "لوحة تحكم الطالب - EduSphere";
}

<div class="container-fluid py-4" dir="rtl">

    <!-- Header Section -->
    <div class="card border-0 shadow-sm rounded-4 bg-primary text-white mb-4 position-relative overflow-hidden">
        <div class="card-body p-4 p-md-5 position-relative z-1">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <span class="badge bg-white text-primary fw-bold mb-2 px-3 py-2 rounded-pill">
                        <i class="bi bi-person-fill ms-1"></i> بوابة الطالب
                    </span>
                    <h2 class="fw-bold mb-1">أهلاً بك، @(Model?.Student?.User?.FullName ?? "طالبنا العزيز")! 👋</h2>
                    <p class="mb-0 text-white-50 fs-6">إليك ملخص شامل لأدائك الأكاديمي والأنشطة الخاصة بك في السنتر.</p>
                </div>
                <div class="d-flex align-items-center bg-white bg-opacity-10 p-3 rounded-4 backdrop-blur">
                    <i class="bi bi-mortarboard-fill display-5 ms-3 opacity-75"></i>
                    <div>
                        <small class="d-block text-white-50">كود الطالب</small>
                        <strong class="fs-5">#@(Model?.Student?.StudentId ?? 0)</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Overview Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary p-3 ms-3">
                        <i class="bi bi-journal-bookmark-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-1">الكورسات المسجلة</h6>
                        <h3 class="fw-bold mb-0 text-dark">@(Model?.EnrolledCoursesCount ?? 0)</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success bg-opacity-10 text-success p-3 ms-3">
                        <i class="bi bi-calendar2-check-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-1">نسبة الحضور</h6>
                        <h3 class="fw-bold mb-0 text-dark">@(Model?.AttendancePercentage ?? 0)%</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 text-warning p-3 ms-3">
                        <i class="bi bi-star-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-1">متوسط الدرجات</h6>
                        <h3 class="fw-bold mb-0 text-dark">@(Model?.AverageGrade ?? 0)</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-info bg-opacity-10 text-info p-3 ms-3">
                        <i class="bi bi-credit-card-2-front-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-1">الاشتراكات النشطة</h6>
                        <h3 class="fw-bold mb-0 text-dark">@(Model?.ActiveSubscriptionsCount ?? 0)</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs Navigation Bar -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-2">
            <ul class="nav nav-pills nav-justified gap-2 flex-column flex-sm-row" id="studentTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active py-3 fw-bold rounded-3" id="courses-tab" data-bs-toggle="tab" data-bs-target="#courses" type="button" role="tab">
                        <i class="bi bi-book ms-2"></i> الكورسات المشترك بها
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link py-3 fw-bold rounded-3" id="exams-tab" data-bs-toggle="tab" data-bs-target="#exams" type="button" role="tab">
                        <i class="bi bi-file-earmark-text ms-2"></i> الامتحانات والنتائج
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link py-3 fw-bold rounded-3" id="subscriptions-tab" data-bs-toggle="tab" data-bs-target="#subscriptions" type="button" role="tab">
                        <i class="bi bi-wallet2 ms-2"></i> الاشتراكات والمدفوعات
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link py-3 fw-bold rounded-3" id="notifications-tab" data-bs-toggle="tab" data-bs-target="#notifications" type="button" role="tab">
                        <i class="bi bi-bell ms-2"></i> الإشعارات والتنويهات
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <!-- Tab Contents Section -->
    <div class="tab-content" id="studentTabContent">

        <!-- 1. TAB: Enrolled Courses -->
        <div class="tab-pane fade show active" id="courses" role="tabpanel">
            <div class="row g-4">
                @if (Model?.EnrolledCourses != null && Model.EnrolledCourses.Any())
                {
                    @foreach (var course in Model.EnrolledCourses)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 hover-card transition-all">
                                <div class="card-body p-4 d-flex flex-column justify-content-between">
                                    <div>
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-bold">مادة دراسية</span>
                                            <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                        </div>
                                        <h5 class="fw-bold text-dark mb-2">@course.Title</h5>
                                        <p class="text-muted small mb-3">@(string.IsNullOrWhiteSpace(course.Description) ? "لا يوجد وصف محدد للمادة." : course.Description)</p>
                                    </div>
                                    <div class="border-top pt-3 mt-3 d-flex justify-content-between align-items-center">
                                        <span class="text-muted small"><i class="bi bi-clock ms-1"></i> حالة التسجيل</span>
                                        <span class="fw-bold text-success">نشط</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 bg-white rounded-4 shadow-sm">
                        <i class="bi bi-journal-x display-1 text-muted opacity-50 mb-3 d-block"></i>
                        <h5 class="text-muted">أنت غير مشترك في أي كورسات حالياً.</h5>
                    </div>
                }
            </div>
        </div>

        <!-- 2. TAB: Exams & Grades -->
        <div class="tab-pane fade" id="exams" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-trophy text-warning ms-2"></i>سجل درجات الامتحانات</h5>
                    <span class="badge bg-light text-dark border">إجمالي الامتحانات: @(Model?.RecentExamResults?.Count() ?? 0)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="py-3 px-4">عنوان الامتحان</th>
                                    <th class="py-3">المادة الدراسية</th>
                                    <th class="py-3">تاريخ الامتحان</th>
                                    <th class="py-3">الدرجة المكتسبة</th>
                                    <th class="py-3 text-center">التقييم</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.RecentExamResults != null && Model.RecentExamResults.Any())
                                {
                                    @foreach (var exam in Model.RecentExamResults)
                                    {
                                        double percentage = exam.MaxScore > 0 ? ((double)exam.Score / exam.MaxScore) * 100 : 0;
                                        <tr>
                                            <td class="py-3 px-4 fw-bold">@exam.ExamTitle</td>
                                            <td><span class="badge bg-primary bg-opacity-10 text-primary">@exam.CourseName</span></td>
                                            <td class="text-muted">@exam.ExamDate.ToString("yyyy/MM/dd")</td>
                                            <td class="fw-bold fs-6">
                                                @exam.Score / <span class="text-muted fs-7">@exam.MaxScore</span>
                                            </td>
                                            <td class="text-center">
                                                @if (percentage >= 85)
                                                {
                                                    <span class="badge bg-success px-3 py-2 rounded-pill">ممتاز 🔥</span>
                                                }
                                                else if (percentage >= 65)
                                                {
                                                    <span class="badge bg-info px-3 py-2 rounded-pill">جيد جداً 👍</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">يحتاج تحسين ⚠️</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">لا توجد نتائج امتحانات مسجلة حتى الآن.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. TAB: Subscriptions & Payment History -->
        <div class="tab-pane fade" id="subscriptions" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-receipt-cutoff text-success ms-2"></i>سجل الاشتراكات والعمليات المالية</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="py-3 px-4">رقم العملية</th>
                                    <th class="py-3">باقة الاشتراك / الخدمة</th>
                                    <th class="py-3">تاريخ الدفع</th>
                                    <th class="py-3">المبلغ</th>
                                    <th class="py-3 text-center">حالة الاشتراك</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.PaymentHistory != null && Model.PaymentHistory.Any())
                                {
                                    @foreach (var payment in Model.PaymentHistory)
                                    {
                                        <tr>
                                            <td class="py-3 px-4 fw-bold text-muted">#@payment.PaymentId</td>
                                            <td class="fw-semibold">@payment.ItemTitle</td>
                                            <td>@payment.PaymentDate.ToString("yyyy/MM/dd")</td>
                                            <td class="fw-bold text-dark">@payment.Amount.ToString("N2") EGP</td>
                                            <td class="text-center">
                                                @if (payment.Status == "مدفوع" || payment.Status == "Active")
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-1 rounded-pill">نشط / مدفوع</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border px-3 py-1 rounded-pill">منتهي</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">لا يوجد سجل مدفوعات متوفر حالياً.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. TAB: Notifications -->
        <div class="tab-pane fade" id="notifications" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-bell-fill text-danger ms-2"></i>الإشعارات والتنويهات الهامة</h5>
                </div>
                <div class="card-body">
                    @if (Model?.Notifications != null && Model.Notifications.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var note in Model.Notifications)
                            {
                                <div class="list-group-item p-3 border-bottom rounded-3 mb-2 bg-light">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold mb-0 text-dark">
                                            <i class="bi bi-info-circle text-primary ms-2"></i>@note.Title
                                        </h6>
                                        <small class="text-muted"><i class="bi bi-clock ms-1"></i>@note.CreatedAt.ToString("g")</small>
                                    </div>
                                    <p class="text-secondary mb-0 ms-4 small">@note.Message</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-bell-slash fs-1 d-block mb-2 text-muted"></i>
                            لا توجد إشعارات جديدة.
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

</div>

@section Styles {
    <style>
        .hover-card {
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .hover-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.08) !important;
            }

        .nav-pills .nav-link {
            color: #555;
            background-color: #f8f9fa;
            transition: all 0.2s ease-in-out;
        }

            .nav-pills .nav-link.active {
                background-color: #0d6efd;
                color: #fff;
            }

        .backdrop-blur {
            backdrop-filter: blur(8px);
        }
    </style>
}