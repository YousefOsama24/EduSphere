@model EduSphere.ViewModel.DashboardVM

@{
    ViewData["Title"] = "Dashboard";
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero-card">

    <div>

        <h2>
            Welcome Back 👋
        </h2>

        <p>
            Manage your educational center efficiently with EduSphere.
        </p>

        <p>
            Here is what's happening today.
        </p>

    </div>

    <div class="hero-date">

        <h5>@DateTime.Now.ToString("dddd")</h5>

        <span>@DateTime.Now.ToString("dd MMMM yyyy")</span>

    </div>

</div>

<div class="stats-grid">

    <div class="stat-card">

        <div class="stat-icon">
            <i class="bi bi-mortarboard-fill"></i>
        </div>

        <div class="stat-info">

            <h3>@Model.TotalStudents</h3>

            <span>Total Students</span>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon">
            <i class="bi bi-person-workspace"></i>
        </div>

        <div class="stat-info">

            <h3>@Model.TotalTeachers</h3>

            <span>Total Teachers</span>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon">
            <i class="bi bi-journal-bookmark-fill"></i>
        </div>

        <div class="stat-info">

            <h3>@Model.TotalCourses</h3>

            <span>Total Courses</span>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon">
            <i class="bi bi-collection-fill"></i>
        </div>

        <div class="stat-info">

            <h3>@Model.TotalGroups</h3>

            <span>Total Groups</span>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon">
            <i class="bi bi-people-fill"></i>
        </div>

        <div class="stat-info">

            <h3>@Model.TotalParents</h3>

            <span>Total Parents</span>

        </div>

    </div>

    <div class="stat-card">

        <div class="stat-icon">
            <i class="bi bi-credit-card-fill"></i>
        </div>

        <div class="stat-info">

            <h3>@Model.ActiveSubscriptions</h3>

            <span>Active Subscriptions</span>

        </div>

    </div>

</div>

<div class="dashboard-row">

    <div class="dashboard-card">

        <h4>Today's Schedule</h4>

        @if (Model.TodaySessions != null && Model.TodaySessions.Any())
        {
            foreach (var session in Model.TodaySessions)
            {
                <div class="schedule-item">

                    <div>

                        <strong>
                            @(session.Group?.Name ?? "Unknown Group")
                        </strong>

                        <div class="text-muted">

                            @session.SessionDate.ToString("dddd")

                        </div>

                    </div>

                    <span class="schedule-time">

                        @session.SessionDate.ToString("hh:mm tt")

                    </span>

                </div>
            }
        }
        else
        {
            <p class="text-muted">

                No sessions scheduled today.

            </p>
        }

    </div>

    <div class="dashboard-card">

        <h4>Expiring Subscriptions</h4>

        @if (Model.ExpiringSubscriptions != null && Model.ExpiringSubscriptions.Any())
        {
            foreach (var subscription in Model.ExpiringSubscriptions)
            {
                <div class="notification-item">

                    <div class="notification-title">

                        @(subscription.SubscriptionPlan?.Name ?? "Subscription")

                    </div>

                    <div class="notification-date">

                        Ends @subscription.EndDate.ToString("dd MMM yyyy")

                    </div>

                </div>
            }
        }
        else
        {
            <p class="text-muted">

                No expiring subscriptions.

            </p>
        }

    </div>

</div>

<div class="table-card">

    <h4 class="mb-4">

        Recent Enrollments

    </h4>

    <table class="table table-hover align-middle">

        <thead>

            <tr>

                <th>Student</th>

                <th>Course</th>

                <th>Date</th>

            </tr>

        </thead>

        <tbody>

        @if(Model.LatestEnrollments != null && Model.LatestEnrollments.Any())
        {
            foreach(var enrollment in Model.LatestEnrollments)
            {
                <tr>

                    <td>

                        @(enrollment.Student?.User?.FullName ?? "-")

                    </td>

                    <td>

                        @(enrollment.Course?.Title?? "-")

                    </td>

                    <td>

                        @enrollment.EnrollmentDate.ToString("dd MMM yyyy")

                    </td>

                </tr>
            }
        }
        else
        {
            <tr>

                <td colspan="3" class="text-center text-muted">

                    No enrollments found.

                </td>

            </tr>
        }

        </tbody>

    </table>

</div>

<div class="action-card mt-4">

    <h4 class="mt-4">

        Quick Actions

    </h4>

    <div class="quick-actions">

        <a asp-area="Center"
           asp-controller="Student"
           asp-action="Create"
           class="quick-card">

            <i class="bi bi-person-plus-fill"></i>

            Add Student

        </a>

        <a asp-area="Center"
           asp-controller="Teachers"
           asp-action="Create"
           class="quick-card">

            <i class="bi bi-person-workspace"></i>

            Add Teacher

        </a>

        <a asp-area="Center"
           asp-controller="Parent"
           asp-action="Create"
           class="quick-card">

            <i class="bi bi-people-fill"></i>

            Add Parent

        </a>

        <a asp-area="Center"
           asp-controller="Student"
           asp-action="Index"
           class="quick-card">

            <i class="bi bi-mortarboard-fill"></i>

            Students

        </a>

        <a asp-area="Center"
           asp-controller="Teachers"
           asp-action="Index"
           class="quick-card">

            <i class="bi bi-person-lines-fill"></i>

            Teachers

        </a>

        <a asp-area="Center"
           asp-controller="Parent"
           asp-action="Index"
           class="quick-card">

            <i class="bi bi-people"></i>

            Parents

        </a>

    </div>

</div>

@section Styles{
<style>
    .dashboard-page {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .hero-card {
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
        color: white;
        border-radius: 22px;
        padding: 35px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        box-shadow: 0 12px 30px rgba(37,99,235,.25);
    }

        .hero-card h2 {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .hero-card p {
            margin-bottom: 8px;
            opacity: .95;
        }

    .hero-date {
        text-align: right;
    }

        .hero-date h5 {
            margin: 0;
            font-weight: 700;
        }

        .hero-date span {
            font-size: .95rem;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 20px;
    }

    .stat-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #e5e7eb;
        box-shadow: 0 5px 15px rgba(0,0,0,.05);
        transition: .3s;
    }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0,0,0,.08);
        }

    .stat-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        background: #eff6ff;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #2563eb;
        font-size: 30px;
    }

    .stat-info {
        text-align: right;
    }

        .stat-info h3 {
            margin: 0;
            font-size: 2rem;
            font-weight: 700;
        }

        .stat-info span {
            color: #6b7280;
        }

    .overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 20px;
    }

    .overview-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
        border: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 5px 15px rgba(0,0,0,.05);
    }

    .overview-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 24px;
    }

    .bg-blue {
        background: #2563eb;
    }

    .bg-red {
        background: #ef4444;
    }

    .bg-green {
        background: #10b981;
    }

    .bg-orange {
        background: #f59e0b;
    }

    .overview-info h5 {
        margin: 0;
        color: #6b7280;
        font-size: .95rem;
    }

    .overview-info h2 {
        margin-top: 8px;
        font-weight: 700;
    }

    .dashboard-row {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 5px 15px rgba(0,0,0,.05);
    }

    .dashboard-card h4 {
        margin-bottom: 20px;
        font-weight: 700;
    }

    .schedule-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #ececec;
    }

    .schedule-item:last-child {
        border-bottom: none;
    }

    .schedule-time {
        color: #2563eb;
        font-weight: 600;
    }

    .notification-item {
        padding: 14px 0;
        border-bottom: 1px solid #ececec;
    }

    .notification-item:last-child {
        border-bottom: none;
    }

    .notification-title {
        font-weight: 600;
    }

    .notification-date {
        color: #6b7280;
        font-size: .85rem;
    }

    .table-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 5px 15px rgba(0,0,0,.05);
        margin-top: 25px;
    }

    .table-card table {
        margin-bottom: 0;
    }

    .table-card thead {
        background: #f8fafc;
    }

    .table-card thead th {
        font-weight: 600;
        color: #374151;
        border: none;
    }

    .table-card tbody td {
        vertical-align: middle;
    }

    .badge-status {
        padding: 8px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-active {
        background: #dcfce7;
        color: #166534;
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
    }

    .quick-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 25px;
        text-align: center;
        transition: .25s;
        text-decoration: none;
        color: #111827;
        box-shadow: 0 5px 15px rgba(0,0,0,.05);
    }

    .quick-card:hover {
        transform: translateY(-6px);
        color: #2563eb;
        box-shadow: 0 15px 35px rgba(0,0,0,.08);
    }

    .quick-card i {
        font-size: 34px;
        margin-bottom: 15px;
        display: block;
    }

    @@media(max-width:992px) {
        .dashboard-row {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width:768px) {
        .hero-card {
            text-align: center;
            justify-content: center;
            gap: 20px;
        }

        .hero-date {
            text-align: center;
        }

        .stat-info {
            text-align: left;
        }

        .quick-actions {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:576px) {
        .quick-actions {
            grid-template-columns: 1fr;
        }
    }
</style>
}
