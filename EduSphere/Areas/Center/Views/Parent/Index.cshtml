@model EduSphere.ViewModel.ParentsVM

@{
    ViewData["Title"] = "قائمة أولياء الأمور";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">إدارة أولياء الأمور</h2>
            <p class="text-muted mb-0">عرض وتعديل كافة بيانات أولياء الأمور بالسنتر</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4 rounded-3 shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i>إضافة ولي أمر جديد
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Box -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text"
                               name="query"
                               value="@ViewBag.Query"
                               class="form-control border-start-0 ps-0"
                               placeholder="ابحث باسم ولي الأمر..." />
                    </div>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold">بحث</button>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Query as string))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary" title="إلغاء البحث">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="ps-4 py-3 text-muted fw-semibold">#</th>
                            <th class="py-3 text-muted fw-semibold">الاسم الكامل</th>
                            <th class="py-3 text-muted fw-semibold">الوظيفة</th>
                            <th class="py-3 text-muted fw-semibold">البريد الإلكتروني / اسم المستخدم</th>
                            <th class="pe-4 py-3 text-end text-muted fw-semibold">العمليات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Parents != null && Model.Parents.Any())
                        {
                            int index = (Model.CurrentPage - 1) * 10 + 1;
                            foreach (var item in Model.Parents)
                            {
                                <tr>
                                    <td class="ps-4 text-secondary fw-semibold">@(index++)</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-3 bg-primary-subtle text-primary fw-bold rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                @(item.User?.FullName?.FirstOrDefault().ToString().ToUpper() ?? "P")
                                            </div>
                                            <span class="fw-semibold text-dark">@(item.User?.FullName ?? "غير محدد")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(string.IsNullOrWhiteSpace(item.Occupation) ? "غير محددة" : item.Occupation)
                                        </span>
                                    </td>
                                    <td class="text-secondary">
                                        @(item.User?.Email ?? item.User?.UserName ?? "N/A")
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Update" asp-route-id="@item.ParentId" class="btn btn-outline-primary" title="تعديل">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal-@item.ParentId"
                                                    title="حذف">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>

                                        <!-- Modal Delete -->
                                        <div class="modal fade" id="deleteModal-@item.ParentId" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered text-start">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title text-danger">تأكيد الحذف</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        هل أنت تأكد من رغبتك في حذف ولي الأمر <strong>@(item.User?.FullName ?? "هذا السجل")</strong>؟
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                                                        <form asp-action="Delete" asp-route-id="@item.ParentId" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-danger">حذف</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-6 d-block mb-2 text-secondary"></i>
                                    لا توجد بيانات لأولياء الأمور حالياً.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top py-3 d-flex justify-content-between align-items-center">
                <span class="text-muted small">
                    صفحة <strong>@Model.CurrentPage</strong> من <strong>@Model.TotalPages</strong>
                </span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-query="@ViewBag.Query">السابق</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-query="@ViewBag.Query">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-query="@ViewBag.Query">التالي</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>