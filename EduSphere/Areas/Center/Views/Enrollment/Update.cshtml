@model EduSphere.Models.Enrollment

@{
    ViewData["Title"] = "Update Enrollment";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Update Enrollment Details</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="EnrollmentId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label fw-semibold">Student ID</label>
                            <input asp-for="StudentId" class="form-control" placeholder="Enter Student ID" />
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CourseId" class="form-label fw-semibold">Course ID</label>
                            <input asp-for="CourseId" class="form-control" placeholder="Enter Course ID" />
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="EnrollmentDate" class="form-label fw-semibold">Enrollment Date</label>
                            <input asp-for="EnrollmentDate" type="date" class="form-control" />
                            <span asp-validation-for="EnrollmentDate" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Update Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

