@model EduSphere.Models.AttendanceSession

@{
    ViewData["Title"] = "Session Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Main Session Info -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-info text-white p-4 rounded-top-4 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Attendance Session Info</h4>
                    <span class="badge bg-white text-dark fs-6">#@Model.AttendanceSessionId</span>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Session Title</small>
                                <span class="fw-bold fs-5 text-dark">@(Model.Title ?? "N/A")</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Teacher Name</small>
                                <span class="fw-bold fs-5 text-dark">@(Model.Teacher?.User?.FullName ?? $"Teacher #{Model.TeacherId}")</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Group Name / ID</small>
                                <span class="fw-bold fs-5 text-primary">@(Model.Group?.Name ?? $"Group #{Model.GroupId}")</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Session Date & Time</small>
                                <span class="fw-bold fs-6 text-dark"><i class="bi bi-calendar-event me-2"></i>@Model.SessionDate.ToString("dd MMMM yyyy - hh:mm tt")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Attendance Records Section -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-person-check me-2"></i>Attendance Records (@(Model.AttendanceRecords?.Count ?? 0))</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Record ID</th>
                                    <th>Student ID</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AttendanceRecords != null && Model.AttendanceRecords.Any())
                                {
                                    @foreach (var record in Model.AttendanceRecords)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold">#@record.AttendanceRecordId</td>
                                            <td><span class="badge bg-light text-dark border">#@record.StudentId</span></td>
                                            <td>
                                                @switch (record.Status)
                                                {
                                                    case EduSphere.Models.AttendanceStatus.Present:
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                            <i class="bi bi-check-circle me-1"></i> حاضر (Present)
                                                        </span>
                                                        break;

                                                    case EduSphere.Models.AttendanceStatus.Late:
                                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                                            <i class="bi bi-clock-history me-1"></i> متأخر (Late)
                                                        </span>
                                                        break;

                                                    case EduSphere.Models.AttendanceStatus.Absent:
                                                    default:
                                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                                            <i class="bi bi-x-circle me-1"></i> غائب (Absent)
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted">
                                            <i class="bi bi-people fs-3 d-block mb-2"></i>
                                            No attendance records logged for this session yet.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                <a asp-action="Update" asp-route-id="@Model.AttendanceSessionId" class="btn btn-primary px-4">Edit Session</a>
            </div>
        </div>
    </div>
</div>