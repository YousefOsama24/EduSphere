@model EduSphere.ViewModel.AttendanceSessionsVM

@{
    ViewData["Title"] = "جلسات الحضور";
}

<style>
    .dragon-container {
        background-color: #121212;
        color: #f8f9fa;
        padding: 25px;
        border-radius: 12px;
        border: 1px solid #8a0303;
        box-shadow: 0 4px 15px rgba(255, 51, 51, 0.15);
    }

    .dragon-title {
        color: #ff4d4d;
        font-weight: bold;
        text-shadow: 0 0 10px rgba(255, 77, 77, 0.3);
    }

    .dragon-btn {
        background: linear-gradient(45deg, #8a0303, #ff3333);
        color: white;
        border: none;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .dragon-btn:hover {
            background: linear-gradient(45deg, #ff3333, #8a0303);
            color: white;
            box-shadow: 0 0 12px rgba(255, 51, 51, 0.6);
            transform: scale(1.02);
        }

    .dragon-table {
        background-color: #1a1a1a;
        color: white;
        border-radius: 8px;
        overflow: hidden;
    }

        .dragon-table th {
            background-color: #222;
            color: #ff4d4d;
            border-bottom: 2px solid #8a0303 !important;
            padding: 15px;
        }

        .dragon-table td {
            border-bottom: 1px solid #333;
            padding: 12px;
            vertical-align: middle;
        }

        .dragon-table tbody tr:hover {
            background-color: #2a0808;
        }

    .dragon-input {
        background-color: #222;
        border: 1px solid #444;
        color: white;
    }

        .dragon-input:focus {
            background-color: #2a2a2a;
            border-color: #ff4d4d;
            color: white;
            box-shadow: 0 0 8px rgba(255, 77, 77, 0.4);
        }
</style>

<div class="container mt-4 dragon-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="dragon-title"><i class="bi bi-calendar-check"></i> إدارة جلسات الحضور</h2>
        <a asp-action="Create" class="btn dragon-btn px-4">إضافة جلسة +</a>
    </div>

    <!-- فورم البحث -->
    <form method="get" asp-action="Index" class="mb-4">
        <div class="input-group shadow-sm">
            <input type="text" name="query" class="form-control dragon-input" placeholder="ابحث باسم المدرس..." value="@ViewBag.Query" />
            <button class="btn dragon-btn" type="submit">بحث</button>
            @if (!string.IsNullOrEmpty(ViewBag.Query))
            {
                <a asp-action="Index" class="btn btn-outline-light">إلغاء</a>
            }
        </div>
    </form>

    <div class="table-responsive rounded shadow">
        <table class="table dragon-table mb-0">
            <thead>
                <tr>
                    <th>عنوان الجلسة</th>
                    <th>المدرس</th>
                    <th>التاريخ والوقت</th>
                    <th class="text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AttendanceSessions.Any())
                {
                    foreach (var item in Model.AttendanceSessions)
                    {
                        <tr>
                            <td class="fw-bold">@item.Title</td>
                            <td>@item.Teacher?.User?.FullName</td>
                            <td><span class="badge bg-dark border border-danger p-2">@item.SessionDate.ToString("yyyy-MM-dd hh:mm tt")</span></td>
                            <td class="text-center">
                                <a asp-action="Update" asp-route-id="@item.AttendanceSessionId" class="btn btn-sm btn-outline-warning">تعديل</a>
                                <a asp-action="Details" asp-route-id="@item.AttendanceSessionId" class="btn btn-sm btn-outline-info">تفاصيل</a>
                                <form asp-action="Delete" asp-route-id="@item.AttendanceSessionId" method="post" class="d-inline" onsubmit="return confirm('متأكد إنك عايز تحذف الجلسة؟');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">لا توجد جلسات متاحة حالياً.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>