@model EduSphere.Models.AttendanceRecord

@{
    ViewData["Title"] = "Attendance Record Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-info text-white p-4 rounded-top-4 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Attendance Record Details</h4>
                    <span class="badge bg-white text-dark fs-6">#@Model.AttendanceRecordId</span>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Student ID / Name</small>
                                <span class="fw-bold fs-5 text-dark">
                                    @(Model.Student?.User?.FullName ?? $"Student #{Model.StudentId}")
                                </span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Session Title</small>
                                <span class="fw-bold fs-5 text-primary">
                                    @(Model.AttendanceSession?.Title ?? $"Session #{Model.AttendanceSessionId}")
                                </span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Status</small>
                                <span class="badge fs-6 mt-1 @(Model.Status.ToString() == "Present" ? "bg-success" : "bg-danger")">
                                    @Model.Status
                                </span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Session Date</small>
                                <span class="fw-bold fs-6 text-dark">
                                    <i class="bi bi-calendar-event me-2"></i>
                                    @(Model.AttendanceSession?.SessionDate.ToString("dd MMMM yyyy - hh:mm tt") ?? "N/A")
                                </span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Notes</small>
                                <p class="mb-0 text-dark mt-1">
                                    @(string.IsNullOrEmpty(Model.Notes) ? "No notes recorded for this attendance." : Model.Notes)
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                <a asp-action="Update" asp-route-id="@Model.AttendanceRecordId" class="btn btn-primary px-4">Edit Record</a>
            </div>
        </div>
    </div>
</div>