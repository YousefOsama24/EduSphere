@model EduSphere.Models.AttendanceRecord

@{
    ViewData["Title"] = "Update Attendance Record";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Update Attendance Record</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="AttendanceRecordId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label fw-semibold">Select Student</label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students">
                                <option value="">-- Choose Student --</option>
                            </select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AttendanceSessionId" class="form-label fw-semibold">Select Session</label>
                            <select asp-for="AttendanceSessionId" class="form-select" asp-items="ViewBag.Sessions">
                                <option value="">-- Choose Session --</option>
                            </select>
                            <span asp-validation-for="AttendanceSessionId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-semibold">Attendance Status</label>
                            <select asp-for="Status" class="form-select" asp-items="@(new SelectList(ViewBag.Statuses))">
                                <option value="">-- Choose Status --</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">Notes (Optional)</label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add any notes regarding attendance..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Update Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

