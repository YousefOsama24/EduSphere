@model EduSphere.ViewModel.StudentsVM

@{
    ViewData["Title"] = "Students";
}

<div class="students-page">

    <!-- =========================
            Hero Section
    ========================== -->

    <div class="page-header">

        <div>

            <h2>Students</h2>

            <p>
                Manage all students in your educational center.
            </p>

        </div>

        <a asp-action="Create"
               class="btn btn-primary">

            <i class="bi bi-plus-circle me-2"></i>

            Add Student

        </a>

    </div>


    <!-- =========================
            Toolbar
    ========================== -->

    <div class="toolbar-card">

        <form method="get">

            <div class="row g-3 align-items-center">

                <div class="col-lg-6">

                    <div class="input-group">

                        <span class="input-group-text">

                            <i class="bi bi-search"></i>

                        </span>

                        <input type="text"
                               name="query"
                               value="@ViewBag.Query"
                               class="form-control"
                               placeholder="Search by student name..." />

                    </div>

                </div>

                <div class="col-auto">

                    <button class="btn btn-primary">

                        <i class="bi bi-search me-2"></i>

                        Search

                    </button>

                </div>

            </div>

        </form>

    </div>

    @if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">

        <i class="bi bi-check-circle-fill me-2"></i>

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">

        <i class="bi bi-exclamation-triangle-fill me-2"></i>

        @TempData["Error"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}
    <!-- =========================
        Students Table
========================== -->

    <div class="table-card">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead>

                    <tr>

                        <th style="width:70px">
                            #
                        </th>

                        <th>
                            Student
                        </th>

                        <th>
                            Parent
                        </th>

                        <th>
                            Created
                        </th>

                        <th class="text-center" style="width:180px">
                            Actions
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Students != null && Model.Students.Any())
                    {
                        foreach (var student in Model.Students)
                        {
                            <tr>

                                <td>

                                    <div class="student-avatar">

                                        @(student.User?.FullName?.Substring(0,1).ToUpper())

                                    </div>

                                </td>

                                <td>

                                    <div class="fw-semibold">

                                        @(student.User?.FullName ?? "-")

                                    </div>

                                    <small class="text-muted">

                                        ID : @student.StudentId

                                    </small>

                                </td>

                                <td>

                                    @(student.Parent?.User?.FullName ?? "No Parent")

                                </td>

                                <td>

                                    @(student.User?.CreatedAt.ToString("dd MMM yyyy"))

                                </td>

                                <td>

                                    <div class="d-flex justify-content-center gap-2">

                                        <a asp-action="Update"
                                               asp-route-id="@student.StudentId"
                                               class="btn btn-sm btn-warning">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@student.StudentId"
                                              method="post">

                                            @Html.AntiForgeryToken()

                                            <button class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Delete this student?')">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </form>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {

                        <tr>

                            <td colspan="5"
                                class="text-center py-5 text-muted">

                                No students found.

                            </td>

                        </tr>

                    }

                </tbody>

            </table>
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">

                    <ul class="pagination justify-content-center">

                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">

                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-query="@ViewBag.Query">

                                <i class="bi bi-chevron-left"></i>

                            </a>

                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">

                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-query="@ViewBag.Query">

                                    @i

                                </a>

                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">

                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-query="@ViewBag.Query">

                                <i class="bi bi-chevron-right"></i>

                            </a>

                        </li>

                    </ul>

                </nav>
            }

        </div>

    </div>










    @section Styles
    {
        <style>
            .pagination{

    margin-bottom:0;

}

.page-link{

    border:none;

    margin:0 4px;

    border-radius:10px !important;

    color:#2563eb;

    min-width:42px;

    text-align:center;

    transition:.25s;

}

.page-link:hover{

    background:#2563eb;

    color:#fff;

}

.page-item.active .page-link{

    background:#2563eb;

    border-color:#2563eb;

    color:#fff;

}

.page-item.disabled .page-link{

    opacity:.5;

}
                .table-card {
                    background: #fff;
                    border-radius: 18px;
                    border: 1px solid #e5e7eb;
                    box-shadow: 0 5px 15px rgba(0,0,0,.05);
                    padding: 25px;
                }

                    .table-card thead {
                        background: #f8fafc;
                    }

                        .table-card thead th {
                            border: none;
                            color: #374151;
                            font-weight: 600;
                        }

                    .table-card tbody td {
                        vertical-align: middle;
                    }

                .student-avatar {
                    width: 46px;
                    height: 46px;
                    border-radius: 50%;
                    background: #2563eb;
                    color: #fff;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    font-weight: 700;
                    font-size: 18px;
                }

                .table tbody tr {
                    transition: .2s;
                }

                    .table tbody tr:hover {
                        background: #f8fbff;
                    }

                .students-page {
                    display: flex;
                    flex-direction: column;
                    gap: 25px;
                }

                .page-header {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    flex-wrap: wrap;
                    gap: 20px;
                }

                    .page-header h2 {
                        font-size: 2rem;
                        font-weight: 700;
                        margin-bottom: 6px;
                    }

                    .page-header p {
                        color: #6b7280;
                        margin: 0;
                    }

                .toolbar-card {
                    background: #fff;
                    padding: 25px;
                    border-radius: 18px;
                    border: 1px solid #e5e7eb;
                    box-shadow: 0 5px 15px rgba(0,0,0,.05);
                }

                .input-group-text {
                    background: #fff;
                }

                .form-control {
                    height: 46px;
                }

                .btn-primary {
                    height: 46px;
                    padding-inline: 22px;
                }

                @@media(max-width:768px) {

                    .page-header {
                        flex-direction: column;
                        align-items: flex-start;
                    }
                }

        </style>
    }