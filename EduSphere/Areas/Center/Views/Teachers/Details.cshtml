@model EduSphere.Models.Teacher

@{
    ViewData["Title"] = "تفاصيل المدرس";
}

<div class="container py-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- زر الرجوع -->
            <div class="d-flex align-items-center gap-2 mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                    <i class="bi bi-arrow-right d-flex"></i>
                </a>
                <span class="text-muted">الرجوع لقائمة المدرسين</span>
            </div>

            <!-- كارت التفاصيل -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-person-badge-fill me-2"></i>تفاصيل البيانات الشخصية
                    </h5>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success px-3 py-2">حساب نشط</span>
                    }
                    else
                    {
                        <span class="badge bg-danger px-3 py-2">حساب غير نشط</span>
                    }
                </div>

                <div class="card-body p-4">
                    <div class="row g-4">

                        <!-- اسم المستخدم / اسم المدرس -->
                        <div class="col-md-6 border-bottom pb-3">
                            <label class="text-muted small fw-semibold d-block mb-1">اسم المدرس</label>
                            <span class="fs-5 fw-bold text-dark">@(Model.User?.UserName ?? "غير محدد")</span>
                        </div>

                        <!-- التخصص -->
                        <div class="col-md-6 border-bottom pb-3">
                            <label class="text-muted small fw-semibold d-block mb-1">التخصص</label>
                            <span class="fs-5 text-dark">@Model.Specialization</span>
                        </div>

                        <!-- السنتر التابع له -->
                        <div class="col-md-6 border-bottom pb-3">
                            <label class="text-muted small fw-semibold d-block mb-1">السنتر</label>
                            <span class="fs-6 text-dark">@(Model.Center?.Name ?? "لا يوجد سنتر مرتبطة")</span>
                        </div>

                        <!-- تاريخ التعيين -->
                        <div class="col-md-6 border-bottom pb-3">
                            <label class="text-muted small fw-semibold d-block mb-1">تاريخ التعيين</label>
                            <span class="fs-6 text-dark">@Model.HireDate.ToString("yyyy-MM-dd")</span>
                        </div>

                        <!-- رقم الهاتف / الايميل إن وجد -->
                        <div class="col-md-6">
                            <label class="text-muted small fw-semibold d-block mb-1">البريد الإلكتروني</label>
                            <span class="fs-6 text-dark">@(Model.User?.Email ?? "غير متوفر")</span>
                        </div>

                        <div class="col-md-6">
                            <label class="text-muted small fw-semibold d-block mb-1">رقم الهاتف</label>
                            <span class="fs-6 text-dark">@(Model.User?.PhoneNumber ?? "غير متوفر")</span>
                        </div>

                    </div>

                    <!-- أزرار التحكم -->
                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light px-4">رجوع</a>
                        <a asp-action="Edit" asp-route-id="@Model.TeacherId" class="btn btn-warning px-4 fw-semibold">
                            <i class="bi bi-pencil-square me-1"></i> تعديل البيانات
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>