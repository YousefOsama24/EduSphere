@model EduSphere.ViewModel.TeachersVM

@{
    ViewData["Title"] = "قائمة المدرسين";
}

<div class="container mt-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold m-0">المدرسين المسجلين</h2>
        <a asp-action="Create" asp-controller="Teachers" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg"></i> Create
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-light">
                        <tr>
                            <th>اسم المدرس</th>
                            <th>السنتر</th>
                            <th>التخصص</th>
                            <th>تاريخ التعيين</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* التعديل هنا: استخدام Model.Teachers أو اسم الـ IEnumerable جوه الـ ViewModel *@
                        @foreach (var item in Model.Teachers)
                        {
                            <tr>
                                <td class="fw-bold">@item.User?.UserName</td>
                                <td>@item.Center?.Name</td>
                                <td>@item.Specialization</td>
                                <td>@item.HireDate.ToString("yyyy-MM-dd")</td>

                                @* تم تصليح وسم الـ td الزيادة هنا *@
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill">غير نشط</span>
                                    }
                                </td>

                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Update" asp-route-id="@item.TeacherId" class="btn btn-sm btn-outline-warning mx-1 rounded">
                                            Update
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.TeacherId" class="btn btn-sm btn-outline-info mx-1 rounded">
                                            Details
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.TeacherId" class="btn btn-sm btn-outline-danger mx-1 rounded">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>