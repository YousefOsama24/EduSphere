@model IEnumerable<EduSphere.Models.Teacher>

@{
    ViewData["Title"] = "قائمة المدرسين";
}
<div class="container mt-4" dir="rtl">
    if (User.IsInRole(SD.SUPER_ADMIN_ROLE) || User.IsInRole(SD.CENTER_ROLE))
    {
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold m-0">المدرسين المسجلين</h2>
        <a asp-action="Create" asp-controller="Teachers" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg"></i> إضافة مدرس جديد
        </a>
    </div>
    }
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-light">
                        <tr>
                            <th>اسم المدرس</th>
                            <th>السنتر</th>
                            <th>التخصص</th>
                            <th>تاريخ التعيين</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.User?.UserName</td>
                                <td>@item.Center?.Name</td>
                                <td>@item.Specialization</td>
                                <td>@item.HireDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-success-custom">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger-custom">غير نشط</span>
                                    }
                                </td>

                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.TeacherId" class="btn btn-sm btn-outline-warning mx-1 rounded">
                                            تعديل
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.TeacherId" class="btn btn-sm btn-outline-info mx-1 rounded">
                                            تفاصيل
                                        </a>
                                        <form asp-action="Delete"
                                              asp-route-id="@item.TeacherId"
                                              method="post"
                                              style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger mx-1 rounded"
                                                    onclick="return confirm('Are you sure you want to delete this teacher?')">
                                                حذف
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
