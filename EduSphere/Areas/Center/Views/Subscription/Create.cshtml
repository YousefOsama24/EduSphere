@model EduSphere.Models.Subscription
@{
    ViewData["Title"] = "إضافة اشتراك جديد";
}

<div class="container py-4" dir="rtl" style="max-width: 700px;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">➕ إضافة اشتراك لمركز</h3>
            <p class="text-muted mb-0 small">ربط مركز تعليمي بخطة اشتراك وتحديد المدة.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-3 px-3">
            <i class="bi bi-arrow-right ms-1"></i> العودة
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CenterId" class="form-label fw-bold small">المركز التعليمي</label>
                        <select asp-for="CenterId" class="form-select rounded-3" asp-items="ViewBag.Centers">
                            <option value="">-- اختر المركز --</option>
                        </select>
                        <span asp-validation-for="CenterId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SubscriptionPlanId" class="form-label fw-bold small">خطة الاشتراك</label>
                        <select asp-for="SubscriptionPlanId" class="form-select rounded-3" asp-items="ViewBag.Plans">
                            <option value="">-- اختر الخطة --</option>
                        </select>
                        <span asp-validation-for="SubscriptionPlanId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold small">تاريخ البداية</label>
                        <input asp-for="StartDate" type="date" class="form-control rounded-3" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold small">تاريخ النهاية</label>
                        <input asp-for="EndDate" type="date" class="form-control rounded-3" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Status" class="form-label fw-bold small">حالة الاشتراك</label>
                        <select asp-for="Status" class="form-select rounded-3">
                            <option value="Active">نشط (Active)</option>
                            <option value="Inactive">غير نشط (Inactive)</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-light rounded-3 px-4">إلغاء</a>
                    <button type="submit" class="btn btn-primary rounded-3 px-4 fw-bold">حفظ الاشتراك</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* @section Scripts {
    <partial name="_ValidationScriptsPartial" />
} *@