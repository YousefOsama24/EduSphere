@model EduSphere.ViewModel.SubscriptionsVM
@{
    ViewData["Title"] = "إدارة اشتراكات المراكز";
}

<div class="container-fluid py-4" dir="rtl">

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">💳 إدارة اشتراكات المراكز</h3>
            <p class="text-muted mb-0 small">عرض وتتبع اشتراكات المراكز التعليمية وصلاحيتها.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-3 px-4 py-2 shadow-sm fw-bold">
            <i class="bi bi-plus-lg ms-1"></i> إضافة اشتراك جديد
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill ms-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill ms-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="query" value="@ViewBag.Query" class="form-control bg-light border-0" placeholder="ابحث برقم الاشتراك، اسم المركز، أو الخطة...">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100 fw-semibold rounded-3">بحث</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3 px-4">رقم الاشتراك</th>
                            <th class="py-3">المركز التعليمي</th>
                            <th class="py-3">خطة الاشتراك</th>
                            <th class="py-3">تاريخ البداية</th>
                            <th class="py-3">تاريخ النهاية</th>
                            <th class="py-3 text-center">الحالة</th>
                            <th class="py-3 text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Subscriptions != null && Model.Subscriptions.Any())
                        {
                            @foreach (var sub in Model.Subscriptions)
                            {
                                <tr>
                                    <td class="py-3 px-4 fw-bold text-muted">#@sub.SubscriptionId</td>
                                    <td class="fw-bold text-dark">@(sub.Center?.Name ?? $"مركز #{sub.CenterId}")</td>
                                    <td>
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                                            @(sub.SubscriptionPlan?.Name ?? $"خطة #{sub.SubscriptionPlanId}")
                                        </span>
                                    </td>
                                    <td class="text-secondary">@sub.StartDate.ToString("yyyy/MM/dd")</td>
                                    <td class="text-secondary">@sub.EndDate.ToString("yyyy/MM/dd")</td>
                                    <td class="text-center">
                                        @if (sub.Status == EduSphere.Models.SubscriptionStatus.Active)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-1 rounded-pill">نشط</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-1 rounded-pill">منتهي / غير نشط</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Update" asp-route-id="@sub.SubscriptionId" class="btn btn-outline-primary btn-sm rounded-3">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger btn-sm rounded-3" data-bs-toggle="modal" data-bs-target="#deleteModal-@sub.SubscriptionId">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                <!-- Delete Modal -->
                                <div class="modal fade" id="deleteModal-@sub.SubscriptionId" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow rounded-4">
                                            <div class="modal-body text-center p-4">
                                                <i class="bi bi-exclamation-circle text-danger display-3 mb-3 d-block"></i>
                                                <h5 class="fw-bold mb-2">تأكيد حذف الاشتراك</h5>
                                                <p class="text-muted small mb-4">هل أنت متأكد من حذف الاشتراك رقم <strong>#@sub.SubscriptionId</strong>؟</p>
                                                <form asp-action="Delete" asp-route-id="@sub.SubscriptionId" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <div class="d-flex justify-content-center gap-2">
                                                        <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">إلغاء</button>
                                                        <button type="submit" class="btn btn-danger rounded-3 px-4">تأكيد الحذف</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">لا توجد اشتراكات مسجلة حالياً.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model?.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link rounded-3 mx-1" asp-action="Index" asp-route-page="@i" asp-route-query="@ViewBag.Query">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

</div>