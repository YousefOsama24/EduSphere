@model EduSphere.ViewModel.SubscriptionPlansVM
@{
    ViewData["Title"] = "خطط الاشتراكات";
}

<div class="container-fluid py-4" dir="rtl">

    <!-- Header Section -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1 text-dark">📋 إدارة خطط الاشتراكات</h3>
            <p class="text-muted mb-0 small">إدارة الباقات والاشتراكات المتاحة للمراكز التعليمية والطلاب.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-3 px-4 py-2 shadow-sm fw-bold">
            <i class="bi bi-plus-lg ms-1"></i> إضافة خطة جديدة
        </a>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill ms-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill ms-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Bar -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="query" value="@ViewBag.Query" class="form-control bg-light border-0" placeholder="ابحث باسم الخطة...">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100 fw-semibold rounded-3">بحث</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Plans Cards View -->
    <div class="row g-4 mb-4">
        @if (Model?.SubscriptionPlans != null && Model.SubscriptionPlans.Any())
        {
            @foreach (var plan in Model.SubscriptionPlans)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 position-relative overflow-hidden hover-card">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-2 rounded-pill fs-7">
                                        المستوى: @plan.Tier
                                    </span>
                                    <h4 class="fw-bold text-primary mb-0">@plan.Price.ToString("N0") <small class="fs-6 text-muted">ج.م</small></h4>
                                </div>

                                <h4 class="fw-bold text-dark mb-2">@plan.Name</h4>
                                <p class="text-muted small mb-3"><i class="bi bi-clock-history ms-1"></i> الملازمة: @plan.DurationInMonths شهور</p>

                                <hr class="text-muted opacity-25">

                                <!-- Features List -->
                                <ul class="list-unstyled mb-4 small text-secondary">
                                    <li class="mb-2"><i class="bi bi-person-badge text-success ms-2"></i> أقصى عدد مدرسين: <strong>@plan.MaxTeachers</strong></li>
                                    <li class="mb-2"><i class="bi bi-people text-success ms-2"></i> أقصى عدد طلاب: <strong>@plan.MaxStudents</strong></li>
                                    @if (!string.IsNullOrWhiteSpace(plan.Features))
                                    {
                                        <li class="mb-2"><i class="bi bi-stars text-warning ms-2"></i> المميزات: @plan.Features</li>
                                    }
                                </ul>
                            </div>

                            <!-- Actions -->
                            <div class="d-flex gap-2 border-top pt-3">
                                <a asp-action="Update" asp-route-id="@plan.SubscriptionPlanId" class="btn btn-outline-primary btn-sm flex-fill rounded-3 fw-semibold">
                                    <i class="bi bi-pencil-square ms-1"></i> تعديل
                                </a>
                                <button type="button" class="btn btn-outline-danger btn-sm flex-fill rounded-3 fw-semibold" data-bs-toggle="modal" data-bs-target="#deleteModal-@plan.SubscriptionPlanId">
                                    <i class="bi bi-trash ms-1"></i> حذف
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Delete Confirmation Modal -->
                <div class="modal fade" id="deleteModal-@plan.SubscriptionPlanId" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow rounded-4">
                            <div class="modal-body text-center p-4">
                                <i class="bi bi-exclamation-circle text-danger display-3 mb-3 d-block"></i>
                                <h5 class="fw-bold mb-2">تأكيد حذف الخطة</h5>
                                <p class="text-muted small mb-4">هل أنت تأكد من إنك عايز تحذف خطة "<strong>@plan.Name</strong>"؟ الإجراء ده مش هينفع ترجع فيه.</p>
                                <form asp-action="Delete" asp-route-id="@plan.SubscriptionPlanId" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">إلغاء</button>
                                        <button type="submit" class="btn btn-danger rounded-3 px-4">تأكيد الحذف</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 bg-white rounded-4 shadow-sm">
                <i class="bi bi-box-seam display-1 text-muted opacity-50 mb-3 d-block"></i>
                <h5 class="text-muted">لا توجد خطط اشتراك مسجلة حالياً.</h5>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model?.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link rounded-3 mx-1" asp-action="Index" asp-route-page="@i" asp-route-query="@ViewBag.Query">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

</div>

@section Styles {
    <style>
        .hover-card {
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .hover-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.08) !important;
            }
    </style>
}