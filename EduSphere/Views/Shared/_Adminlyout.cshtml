@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    Func<string, string> activeIf = (action) =>
        currentAction.Equals(action, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] | لوحة السوبر أدمن</title>

    <link rel="stylesheet" href="~/css/tokens.css" />
    <link rel="stylesheet" href="~/css/admin-layout.css" />
    @RenderSection("Styles", required: false)
</head>
<body class="admin-page">

    <div class="admin-shell">

        <!-- ===== Sidebar (خاص بالأدمن فقط) ===== -->
        <aside class="admin-sidebar" id="admin-sidebar">
            <div class="brand">
                <span class="mark">AK</span>
                لوحة السوبر أدمن
            </div>

            <div class="section-label">النظرة العامة</div>
            <ul class="admin-nav">
                <li><a href="@Url.Action("Dashboard", "Admin")" class="@activeIf("Dashboard")"><span class="dot"></span> الرئيسية</a></li>
                <li><a href="@Url.Action("Reports", "Admin")" class="@activeIf("Reports")"><span class="dot"></span> التقارير</a></li>
            </ul>

            <div class="section-label">الإدارة</div>
            <ul class="admin-nav">
                <li><a href="@Url.Action("Courses", "Admin")" class="@activeIf("Courses")"><span class="dot"></span> الدورات التدريبية</a></li>
                <li><a href="@Url.Action("Instructors", "Admin")" class="@activeIf("Instructors")"><span class="dot"></span> المدرّسون</a></li>
                <li><a href="@Url.Action("Students", "Admin")" class="@activeIf("Students")"><span class="dot"></span> الطلاب</a></li>
                <li><a href="@Url.Action("Payments", "Admin")" class="@activeIf("Payments")"><span class="dot"></span> المدفوعات</a></li>
            </ul>

            <div class="section-label">النظام</div>
            <ul class="admin-nav">
                <li><a href="@Url.Action("Roles", "Admin")" class="@activeIf("Roles")"><span class="dot"></span> صلاحيات المستخدمين</a></li>
                <li><a href="@Url.Action("Settings", "Admin")" class="@activeIf("Settings")"><span class="dot"></span> إعدادات الموقع</a></li>
            </ul>

            <div class="sidebar-footer">
                إصدار النظام 3.2.1<br />
                آخر نسخة احتياطية: منذ ساعتين
            </div>
        </aside>

        <div class="admin-scrim" id="admin-scrim"></div>

        <!-- ===== Main column ===== -->
        <div class="admin-main">

            <header class="admin-topbar">
                <button class="sidebar-toggle" id="sidebar-toggle" aria-label="فتح القائمة" aria-expanded="false">☰</button>

                <div class="title-block">
                    <div class="page-title">@ViewData["PageTitle"]</div>
                    <div class="page-sub">@ViewData["PageSubtitle"]</div>
                </div>

                <div class="search-box">
                    <input type="text" id="admin-search" placeholder="ابحث في سجل النشاط..." />
                </div>

                <div class="admin-profile">
                    <div class="avatar">@ViewData["AdminInitials"]</div>
                    <div>
                        <div class="name">@ViewData["AdminName"]</div>
                        <div class="role">سوبر أدمن</div>
                    </div>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="admin-toast" id="admin-toast"></div>

    <script src="~/js/admin-layout.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
