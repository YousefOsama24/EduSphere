@using Microsoft.AspNetCore.Identity
@using EduSphere.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    // Single source of truth for "which area is the current user's home area".
    // Student/Parent don't have their own Areas yet - their dashboards live
    // under Center (see Areas/Center/Controllers/HomeController: StudentDashboard/ParentDashboard).
    // Update this if/when dedicated Student/Parent Areas are added.
    var currentArea = "Center";

    if (User.IsInRole("Teacher"))
    {
        currentArea = "Teacher";
    }
    else if (User.IsInRole("SuperAdmin"))
    {
        currentArea = "SuperAdmin";
    }
    else if (User.IsInRole("Student") || User.IsInRole("Parent"))
    {
        currentArea = "Center";
    }
}

<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - EduSphere</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Shared Design Tokens -->
    <link rel="stylesheet"
          href="~/css/tokens.css"
          asp-append-version="true" />

    <!-- Main Site CSS -->
    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <!-- Site Layout -->
    <link rel="stylesheet"
          href="~/css/site-layout.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/sidebar.css"
          asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @await RenderSectionAsync("Styles", required: false)


</head>

<body class="bg-light">

    <div class="content-wrapper">

        <div class="app-wrapper d-flex flex-column min-vh-100">
            <div class="layout">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("CenterManager"))
                    {
                        <partial name="~/Areas/Center/Views/Shared/_Sidebar.cshtml" />
                    }
                    else if (User.IsInRole("Teacher"))
                    {
                        <partial name="~/Areas/Teacher/Views/Shared/_Sidebar.cshtml" />
                    }
                    else if (User.IsInRole("Student") || User.IsInRole("Parent"))
                    {
                        @* Student/Parent have no dedicated Area yet - reuse the Center sidebar
                           until a real Student/Parent sidebar partial exists. *@
                        <partial name="~/Areas/Center/Views/Shared/_Sidebar.cshtml" />
                    }
                    else if (User.IsInRole("SuperAdmin"))
                    {
                        <partial name="~/Areas/SuperAdmin/Views/Shared/_Sidebar.cshtml" />
                    }
                }
                <div class="main-wrapper">

                    <button id="sidebarToggle"
                            class="btn btn-light border">

                        <i class="bi bi-list"></i>

                    </button>
                    <!-- ===========================
                            TOPBAR
                    ============================ -->

                    <header class="topbar shadow-sm">

                        <div class="container-fluid">

                            <div class="d-flex justify-content-between align-items-center">

                                <!-- Left -->

                                <div class="d-flex align-items-center gap-3">

                                    <!--  Sidebar Toggle -->

                                    <button id="sidebarToggleMobile"
                                            class="btn btn-light border d-lg-none">

                                        <i class="bi bi-list fs-5"></i>

                                    </button>

                                    <!-- Search -->

                                    <div class="search-box d-none d-md-block">

                                        <div class="input-group">

                                            <span class="input-group-text bg-white border-end-0">

                                                <i class="bi bi-search text-secondary"></i>

                                            </span>

                                            <input
                                                type="text"
                                                class="form-control border-start-0"
                                                   placeholder="Search students, teachers..." />

                                        </div>

                                    </div>

                                </div>

                                <!-- Right -->

                                <div class="d-flex align-items-center gap-3">

                                    <!-- Language -->

                                    <button class="btn btn-light position-relative">

                                        <span class="fw-semibold small">EN</span>

                                    </button>

                                    <!-- Notification -->

                                    <button class="btn btn-light position-relative">

                                        <i class="bi bi-bell"></i>

                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">

                                            3

                                        </span>

                                    </button>

                                    <!-- User -->

                                    @if(User.Identity!.IsAuthenticated)
                                    {

                                        <div class="dropdown">

                                            <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2"
                                                    data-bs-toggle="dropdown">

                                                <img src="https://ui-avatars.com/api/?name=EduSphere"
                                                     width="36"
                                                     height="36"
                                                     class="rounded-circle" />

                                                <span class="fw-semibold">

                                                    @(User.Identity?.Name)

                                                </span>

                                            </button>

                                            <ul class="dropdown-menu dropdown-menu-end">

                                                <li>

                                                    <a class="dropdown-item"
                                                       asp-area="Identity"
                                                       asp-controller="Account"
                                                       asp-action="Profile">

                                                        <i class="bi bi-person me-2"></i>

                                                        Profile

                                                    </a>

                                                </li>

                                                <li>

                                                    <hr class="dropdown-divider"/>

                                                </li>

                                                <li>

                                                    <form asp-area="Identity"
                                                          asp-controller="Account"
                                                          asp-action="Logout"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button class="dropdown-item text-danger">

                                                            <i class="bi bi-box-arrow-right me-2"></i>

                                                            Logout

                                                        </button>

                                                    </form>

                                                </li>

                                            </ul>

                                        </div>

                                    }

                                </div>

                            </div>

                        </div>

                    </header>

                    <!-- ===========================
                            BODY
                    ============================ -->

                    <div class="container-fluid">

                        <div class="row">

                            <!-- ====================================
                                    Sidebar 
                            ===================================== -->
                                       
                            <!-- Main Content -->

                            <main class="flex-grow-1 px-4 py-4">

                                <!-- ======================
                                       Breadcrumb
                                ======================= -->

                                <div class="mb-4">

                                    <nav aria-label="breadcrumb">

                                        <ol class="breadcrumb">

                                            <li class="breadcrumb-item">

                                                <a asp-area="@currentArea"
                                                   asp-controller="Home"
                                                   asp-action="Index">

                                                    Dashboard

                                                </a>

                                            </li>

                                            @if(ViewData["Title"] != null &&
                                                ViewData["Title"]!.ToString() != "Dashboard")
                                            {
                                                <li class="breadcrumb-item active">

                                                    @ViewData["Title"]

                                                </li>
                                            }

                                        </ol>

                                    </nav>

                                </div>

                                <!-- ======================
                                       PAGE TITLE
                                ======================= -->

                                @if(ViewData["Title"] != null)
                                {

                                    <div class="mb-4">

                                        <h2 class="fw-bold text-dark">

                                            @ViewData["Title"]

                                        </h2>

                                    </div>

                                }

                                <!-- ======================
                                       CONTENT
                                ======================= -->

                                <div class="page-content">

                                    @if (TempData["Success"] != null)
                                    {
                                        <div class="alert alert-success alert-dismissible fade show">

                                            @TempData["Success"]

                                            <button class="btn-close"
                                                    data-bs-dismiss="alert">
                                            </button>

                                        </div>
                                    }

                                    @if (TempData["Error"] != null)
                                    {
                                        <div class="alert alert-danger alert-dismissible fade show">

                                            @TempData["Error"]

                                            <button class="btn-close"
                                                    data-bs-dismiss="alert">
                                            </button>

                                        </div>
                                    }

                                    @if (TempData["Warning"] != null)
                                    {
                                        <div class="alert alert-warning alert-dismissible fade show">

                                            @TempData["Warning"]

                                            <button class="btn-close"
                                                    data-bs-dismiss="alert">
                                            </button>

                                        </div>
                                    }

                                    @RenderBody()

                                </div>

                            </main>
                                        
                        </div>

                    </div>
                    <!-- ===========================
                                FOOTER
                    ============================ -->

                    <footer class="border-top bg-white mt-auto">

                        <div class="container-fluid">

                            <div class="row align-items-center py-3">

                                <div class="col-md-6 text-center text-md-start">

                                    <span class="text-muted">

                                        © @DateTime.Now.Year
                                        <strong>EduSphere</strong>
                                        All Rights Reserved.

                                    </span>

                                </div>

                                <div class="col-md-6 text-center text-md-end">

                                    <span class="text-muted">

                                        Educational Management Platform

                                    </span>

                                </div>

                            </div>

                        </div>

                    </footer>

                </div>
                <!-- /main-wrapper -->
            </div>
            <!-- /layout -->
        </div>
        <!-- /app-wrapper -->
    </div>
    <!-- /content-wrapper -->

    <!-- ===========================
        SCRIPTS
=========================== -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
        (function () {
            const sidebar = document.querySelector(".sidebar");
            const content = document.querySelector(".content-wrapper");
            const toggles = [
                document.getElementById("sidebarToggle"),
                document.getElementById("sidebarToggleMobile")
            ];

            function toggleSidebar() {
                if (!sidebar || !content) {
                    console.warn("Sidebar toggle skipped: .sidebar or .content-wrapper not found in DOM.");
                    return;
                }
                sidebar.classList.toggle("collapsed");
                content.classList.toggle("expanded");
            }

            toggles.forEach(function (btn) {
                if (btn) {
                    btn.addEventListener("click", toggleSidebar);
                }
            });
        })();
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
