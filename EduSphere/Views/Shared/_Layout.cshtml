@{
    // احسب المسار الحالي عشان نحدّد الرابط النشط في القائمة
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    Func<string, string, string> activeIf = (controller, action) =>
        (currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
         (action == "*" || currentAction.Equals(action, StringComparison.OrdinalIgnoreCase)))
            ? "active" : "";
}
<!DOCTYPE html>
<html lang="en" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] EduSphere </title>

    <link rel="stylesheet" href="~/css/tokens.css" />
    <link rel="stylesheet" href="~/css/site-layout.css" />
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ===== Top bar (مشترك في كل صفحات الموقع) ===== -->
    <header class="site-topbar" id="site-topbar">
        <a class="brand" href="@Url.Action("Index", "Home")">
            <span class="mark">AK</span>
            EduSphere
        </a>

        <nav class="site-nav" id="site-nav">
            <a class="@activeIf("Home", "Index")" href="@Url.Action("Index", "Home")">Home</a>
            <a class="@activeIf("Courses", "*")" href="@Url.Action("Index", "Courses")">Courses</a>
            <a class="@activeIf("Instructors", "*")" href="@Url.Action("Index", "Instructors")">Instructors</a>
            <a class="@activeIf("Home", "About")" href="@Url.Action("About", "Home")">من نحن</a>
        </nav>

        <button class="nav-toggle" id="nav-toggle" aria-label="فتح القائمة" aria-expanded="false">
            <span class="bar"></span><span class="bar"></span><span class="bar"></span>
        </button>

        <a class="cta-btn" href="@Url.Action("Register", "Account")">سجّل الآن</a>
    </header>

    <div class="nav-scrim" id="nav-scrim"></div>

    <!-- ===== محتوى الصفحة ===== -->
    @RenderBody()

    <!-- ===== الفوتر (مشترك) ===== -->
    <footer class="site-footer">
        <div class="footer-grid">
            <div>
                <div class="brand">أكاديمية المعرفة</div>
                <p>منصة تدريبية تجمع نخبة من المدرّبين المعتمدين لتقديم دورات موثّقة في مختلف المجالات.</p>
            </div>
            <div>
                <h4>روابط سريعة</h4>
                <ul>
                    <li><a href="@Url.Action("Index", "Courses")"> Courses</a></li>
                    <li><a href="@Url.Action("Index", "Instructors")">Instructors</a></li>
                    <li><a href="@Url.Action("About", "Home")">من نحن</a></li>
                </ul>
            </div>
            <div>
                <h4>تواصل معنا</h4>
                <ul>
                    <li>support@akademya.example</li>
                    <li>+20 100 000 0000</li>
                </ul>
            </div>
        </div>
        <p class="copyright">© @DateTime.Now.Year أكاديمية المعرفة — جميع الحقوق محفوظة</p>
    </footer>

    <script src="~/js/site-layout.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
