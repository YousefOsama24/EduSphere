
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Teacher Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
</head>
<body data-role="teacher">

    <div class="app-shell">

        <!-- Sidebar -->
        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-brand">
                <div class="mark">B</div>
                <div>
                    <div class="name">EduSphere </div>
                    <div class="sub">Learning Center</div>
                </div>
            </div>
            <div class="sidebar-role-tab"><i class="bi bi-easel me-1"></i> Teacher portal</div>

            <nav class="sidebar-nav">
                <div class="nav-section">Main</div>


                <a class="nav-link" href="/Teacher/Home/Index"><i class="bi bi-calendar2-check"></i> Home</a>
                <a class="nav-link" href="/Center/Student/Index"><i class="bi bi-calendar2-check"></i> Student</a>
                @* <a class="nav-link" href="/Center/Schedule/Index"><i class="bi bi-calendar2-check"></i> Schedule</a> *@
                <a class="nav-link" href="/Center/AttendanceSession/Index"><i class="bi bi-calendar2-check"></i> AttendanceSession</a>
                <a class="nav-link" href="/Center/AttendanceRecord/Index"><i class="bi bi-calendar2-check"></i> AttendanceRecord</a>
                <a class="nav-link" href="/Teacher/Course/Index"><i class="bi bi-calendar2-check"></i> Courses</a>
                <a class="nav-link" href="/Teacher/Group/Index"><i class="bi bi-calendar2-check"></i> Groups</a>
                <a class="nav-link" href="/Teacher/Exam/Index"><i class="bi bi-calendar2-check"></i> Exams</a>
                <a class="nav-link" href="/Teacher/Question/Index"><i class="bi bi-calendar2-check"></i> Question</a>
                <a class="nav-link" href="/Teacher/Choice/Index"><i class="bi bi-calendar2-check"></i> Choice</a>
                <a class="nav-link" href="/Teacher/StudentAnswer/Index"><i class="bi bi-calendar2-check"></i> StudentAnswer</a>
                <a class="nav-link" href="/Teacher/Lecture/Index"><i class="bi bi-calendar2-check"></i> Lectures</a>



                <div class="nav-section">Account</div>
                <a class="nav-link" href="#">
                    <i class="bi bi-chat-dots"></i> Messages
                    <span class="badge rounded-pill ms-auto" style="background:var(--pen-red); font-size:.65rem;">5</span>
                </a>
                <a class="nav-link" href="#"><i class="bi bi-gear"></i> Settings</a>
                <a class="nav-link" href="index.html"><i class="bi bi-box-arrow-left"></i> Sign out</a>
            </nav>

            <div class="sidebar-foot">
                <div class="id-badge">LF</div>
                <div class="who">
                    Mrs. Ferrara<br>
                    <small>Science Department</small>
                </div>
            </div>
        </aside>
        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>
        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/script.js"></script>
    <script>
        new Chart(document.getElementById('perfChart'), {
          type: 'bar',
          data: {
            labels: ['Quiz 1','Quiz 2','Lab 1','Quiz 3','Midterm mock','Lab 2'],
            datasets: [{
              label: 'Class average %',
              data: [79, 82, 75, 84, 80, 86],
              backgroundColor: '#2F5D3A',
              borderRadius: 4,
              maxBarThickness: 34
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, max: 100, grid: { color: '#EAE3D0' } },
              x: { grid: { display: false } }
            }
          }
        });
    </script>
</body>
</html>
